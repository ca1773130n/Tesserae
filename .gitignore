# Local research corpus and generated artifacts
data/
evals/
output/

# But: the demo corpus under examples/ IS checked in.
!examples/demo-corpus/data/
!examples/demo-corpus/data/**

# Python caches
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
*.egg-info/

# PyPI build artifacts (from `python -m build`)
dist/
build/

# pip transient scratch dirs that leak into cwd when a pip run is
# interrupted or TMPDIR resolves here. Normally auto-deleted under
# $TMPDIR; ignored so an interrupted install never clutters git.
pip-build-tracker-*/
pip-ephem-wheel-cache-*/
pip-install-*/
pip-unpack-*/
pip-build-env-*/
pip-metadata-*/
pip-modern-metadata-*/

# Local graph/database outputs
.tesserae/
.understand-anything/
*.sqlite
*.kuzu/
*.duckdb

# Local agent session markers
.agent-sessions/
# ...but the demo corpus ships hand-authored agent-session transcripts.
!examples/demo-corpus/.agent-sessions/
!examples/demo-corpus/.agent-sessions/**
.hermes/
.tesserae/external/raganything/working_dir/
.tesserae/external/raganything/parsed/

# pytest temp directories — created when tmp_path_factory points at the repo
pytest-of-*/
node-compile-cache/

# Local IDE / AI-assistant configs — per-developer, do not commit
.agents/
.aider.conf.yml
.aider*
.avante/
.claude/
.clinerules
.codecompanion/
.codex/
.continue/
.cursor/
.gemini/
.harness-sync/
.opencode/
.playwright-mcp/
.roo/
.zed/

# Per-developer agent system prompts and convention overlays
AGENTS.md
CLAUDE.md
GEMINI.md
CONVENTIONS.md
SYNC-CHANGELOG.md
config.toml
opencode.json
data-gym-cache/

# uv lockfiles can vary by lockfile version + platform — keep out of tree
uv-*.lock

# grd evolve / autopilot planning artifacts — per-developer state
.planning/
