  <data key="d1">person</data>
  <data key="d2">Yaron Lipman is an author of Implicit Geometric Regularization for Learning Shapes.&lt;SEP&gt;Yaron Lipman is an author of Volume Rendering of Neural Implicit Surfaces.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735&lt;SEP&gt;chunk-62f6aaf4d349907fedafca12c9a53bdb</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2106-12052/paper.md</data>
  <data key="d5">1778876783</data>
  <data key="d6"></data>
</node>
<node id="Neural Signed Distance Functions">
  <data key="d0">Neural Signed Distance Functions</data>
  <data key="d1">method</data>
  <data key="d2">Neural Signed Distance Functions are coordinate-based networks fitted by the proposed method to represent surfaces from point cloud data.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Raw Point Clouds">
  <data key="d0">Raw Point Clouds</data>
  <data key="d1">data</data>
  <data key="d2">Raw Point Clouds are the input data used by the method for direct fitting without explicit occupancy supervision.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Zero-Set Term">
  <data key="d0">Zero-Set Term</data>
  <data key="d1">concept</data>
  <data key="d2">Zero-Set Term is a loss term that encourages the network to vanish on input points and can optionally use surface normals.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Eikonal Regularizer">
  <data key="d0">Eikonal Regularizer</data>
  <data key="d1">method</data>
  <data key="d2">Eikonal Regularizer is the core regularization term that encourages the gradient of the network to have unit norm everywhere in ambient space.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Surface Normals">
  <data key="d0">Surface Normals</data>
  <data key="d1">data</data>
  <data key="d2">Surface Normals are optional geometric information that can be used together with input points in the zero-set term.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="DeepSDF-Style Methods">
  <data key="d0">DeepSDF-Style Methods</data>
  <data key="d1">method</data>
  <data key="d2">DeepSDF-Style Methods are compared methods that require pre-computed ground-truth SDF samples.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Ground-Truth SDF Samples">
  <data key="d0">Ground-Truth SDF Samples</data>
  <data key="d1">data</data>
  <data key="d2">Ground-Truth SDF Samples are explicit supervision data required by DeepSDF-style methods.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Occupancy Networks">
  <data key="d0">Occupancy Networks</data>
  <data key="d1">method</data>
  <data key="d2">Occupancy Networks are compared methods that require explicit inside/outside labels.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Inside/Outside Labels">
  <data key="d0">Inside/Outside Labels</data>
  <data key="d1">data</data>
  <data key="d2">Inside/Outside Labels are explicit supervision signals required by Occupancy Networks.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Sparse Oriented Points">
  <data key="d0">Sparse Oriented Points</data>
  <data key="d1">data</data>
  <data key="d2">Sparse Oriented Points are one form of point-based input from which the method recovers high-fidelity surfaces.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Unoriented Points">
  <data key="d0">Unoriented Points</data>
  <data key="d1">data</data>
  <data key="d2">Unoriented Points are another form of point-based input from which the method recovers high-fidelity surfaces.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="High-Fidelity Surfaces">
  <data key="d0">High-Fidelity Surfaces</data>
  <data key="d1">artifact</data>
  <data key="d2">High-Fidelity Surfaces are the recovered surface outputs produced by the method from sparse oriented points and unoriented points.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Signed Distance Field">
  <data key="d0">Signed Distance Field</data>
  <data key="d1">concept</data>
  <data key="d2">Signed Distance Field is the field representation whose well-behavedness is maintained by the inherited Eikonal regularizer.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Classical Level-Set Methods">
  <data key="d0">Classical Level-Set Methods</data>
  <data key="d1">method</data>
  <data key="d2">Classical Level-Set Methods are an earlier reconstruction approach from which the paper forms a bridge.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Volume-Rendering Era Surface Reconstruction Lineage">
  <data key="d0">Volume-Rendering Era Surface Reconstruction Lineage</data>
  <data key="d1">concept</data>
  <data key="d2">Volume-Rendering Era Surface Reconstruction Lineage is the later reconstruction lineage led by NeuS and VolSDF that the paper helps connect to earlier methods.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="3D Reconstruction Corpus">
  <data key="d0">3D Reconstruction Corpus</data>
  <data key="d1">concept</data>
  <data key="d2">3D Reconstruction Corpus is the broader research context in which the paper serves as a bridge between methodological eras.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Ground-Truth Occupancy">
  <data key="d0">Ground-Truth Occupancy</data>
  <data key="d1">data</data>
  <data key="d2">Ground-Truth Occupancy is supervised occupancy information that Implicit Geometric Regularization does not require for fitting neural signed distance functions to raw point clouds.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Smooth Zero Level Sets">
  <data key="d0">Smooth Zero Level Sets</data>
  <data key="d1">artifact</data>
  <data key="d2">Smooth Zero Level Sets are clean manifold surfaces that the Eikonal regularizer biases the network toward in the linear regime.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Direct Chamfer-Style Fitting">
  <data key="d0">Direct Chamfer-Style Fitting</data>
  <data key="d1">method</data>
  <data key="d2">Direct Chamfer-Style Fitting is a fitting approach associated with producing noisy and fragmented implicit surfaces.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Noisy Fragmented Implicit Surfaces">
  <data key="d0">Noisy Fragmented Implicit Surfaces</data>
  <data key="d1">artifact</data>
  <data key="d2">Noisy Fragmented Implicit Surfaces are undesirable surface outputs contrasted with the smooth zero level sets encouraged by the regularizer.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Coordinate-Based Networks">
  <data key="d0">Coordinate-Based Networks</data>
  <data key="d1">method</data>
  <data key="d2">Coordinate-Based Networks are the class of networks to which the paper applies a carefully chosen regularization term.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Explicit Supervision">
  <data key="d0">Explicit Supervision</data>
  <data key="d1">data</data>
  <data key="d2">Explicit Supervision is supervision produced by expensive pre-processing pipelines and described as replaceable by the paper's regularization approach.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="Pre-Processing Pipelines">
  <data key="d0">Pre-Processing Pipelines</data>
  <data key="d1">method</data>
  <data key="d2">Pre-Processing Pipelines are expensive procedures that produce explicit supervision for reconstruction methods.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876529</data>
  <data key="d6"></data>
</node>
<node id="2D Gaussian Splatting for Geometrically Accurate Radiance Fields">
  <data key="d0">2D Gaussian Splatting for Geometrically Accurate Radiance Fields</data>
  <data key="d1">content</data>
  <data key="d2">2D Gaussian Splatting for Geometrically Accurate Radiance Fields is a paper that introduces 2D Gaussian Splatting as a geometry-aware alternative to 3D Gaussian Splatting for radiance fields.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876586</data>
  <data key="d6"></data>
</node>
<node id="Binbin Huang">
  <data key="d0">Binbin Huang</data>
  <data key="d1">person</data>
  <data key="d2">Binbin Huang is an author of 2D Gaussian Splatting for Geometrically Accurate Radiance Fields.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876586</data>
  <data key="d6"></data>
</node>
<node id="Anpei Chen">
  <data key="d0">Anpei Chen</data>
  <data key="d1">person</data>
  <data key="d2">Anpei Chen is an author of 2D Gaussian Splatting for Geometrically Accurate Radiance Fields.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876586</data>
  <data key="d6"></data>
</node>
<node id="Shenghua Gao">
  <data key="d0">Shenghua Gao</data>
  <data key="d1">person</data>
  <data key="d2">Shenghua Gao is an author of 2D Gaussian Splatting for Geometrically Accurate Radiance Fields.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876586</data>
  <data key="d6"></data>
</node>
<node id="Gaussian Disk">
  <data key="d0">Gaussian Disk</data>
  <data key="d1">artifact</data>
  <data key="d2">A Gaussian disk is a flat oriented primitive in 3D space with a single normal and a well-defined location, intrinsically representing a tangent plane to an underlying surface.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Perspective-Correct Splatting Process">
  <data key="d0">Perspective-Correct Splatting Process</data>
  <data key="d1">method</data>
  <data key="d2">Perspective-Correct Splatting Process is the rendering process used to recover radiance from Gaussian disks through explicit ray-splat intersection.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Ray-Splat Intersection">
  <data key="d0">Ray-Splat Intersection</data>
  <data key="d1">method</data>
  <data key="d2">Ray-Splat Intersection is the explicit geometric derivation used in 2D Gaussian Splatting instead of a screen-space affine approximation.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Screen-Space Affine Approximation">
  <data key="d0">Screen-Space Affine Approximation</data>
  <data key="d1">method</data>
  <data key="d2">Screen-Space Affine Approximation is the approximation used by 3D Gaussian Splatting instead of explicit ray-splat intersection.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Depth Distortion Term">
  <data key="d0">Depth Distortion Term</data>
  <data key="d1">method</data>
  <data key="d2">Depth Distortion Term is a regulariser that encourages the depth distribution along each ray to be sharply peaked on a single disk.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Normal Consistency Term">
  <data key="d0">Normal Consistency Term</data>
  <data key="d1">method</data>
  <data key="d2">Normal Consistency Term is a regulariser that encourages disk normals to agree with the gradient of the rendered depth map.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Rendered Depth Map">
  <data key="d0">Rendered Depth Map</data>
  <data key="d1">data</data>
  <data key="d2">Rendered Depth Map is the depth output whose gradient is used by the normal consistency term.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Noise-Free Meshes">
  <data key="d0">Noise-Free Meshes</data>
  <data key="d1">artifact</data>
  <data key="d2">Noise-Free Meshes are geometric outputs produced by the regularised 2D Gaussian Splatting method.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Clean Surface Normals">
  <data key="d0">Clean Surface Normals</data>
  <data key="d1">data</data>
  <data key="d2">Clean Surface Normals are geometric outputs produced by the regularised 2D Gaussian Splatting method.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Neural Implicit Surface Methods">
  <data key="d0">Neural Implicit Surface Methods</data>
  <data key="d1">method</data>
  <data key="d2">Neural Implicit Surface Methods are geometry-oriented methods whose output quality is described as competitive with that of 2D Gaussian Splatting.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Gaussian-Based Radiance Fields">
  <data key="d0">Gaussian-Based Radiance Fields</data>
  <data key="d1">concept</data>
  <data key="d2">Gaussian-Based Radiance Fields are fast radiance field approaches that are being connected to more accurate geometry by methods such as 2D Gaussian Splatting and SuGaR.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Accurate Geometry">
  <data key="d0">Accurate Geometry</data>
  <data key="d1">concept</data>
  <data key="d2">Accurate Geometry is the geometric objective that 2D Gaussian Splatting is designed to improve relative to 3D Gaussian Splatting.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="hbb1/2d-gaussian-splatting">
  <data key="d0">hbb1/2d-gaussian-splatting</data>
  <data key="d1">artifact</data>
  <data key="d2">hbb1/2d-gaussian-splatting is the released code repository associated with the paper and is described as a common baseline for surface-aware Gaussian methods.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Surface-Aware Gaussian Methods">
  <data key="d0">Surface-Aware Gaussian Methods</data>
  <data key="d1">method</data>
  <data key="d2">Surface-Aware Gaussian Methods are Gaussian methods focused on surface quality, for which the released 2D Gaussian Splatting code serves as a common baseline.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Tangent Plane">
  <data key="d0">Tangent Plane</data>
  <data key="d1">concept</data>
  <data key="d2">A tangent plane is the surface-oriented plane that each Gaussian disk intrinsically represents in 3D space.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Underlying Surface">
  <data key="d0">Underlying Surface</data>
  <data key="d1">concept</data>
  <data key="d2">The underlying surface is the scene surface to which each Gaussian disk is described as being tangent.</data>
  <data key="d3">chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-17888/paper.md</data>
  <data key="d5">1778876588</data>
  <data key="d6"></data>
</node>
<node id="Daily Digest 2026-04-15">
  <data key="d0">Daily Digest 2026-04-15</data>
  <data key="d1">content</data>
  <data key="d2">Daily Digest 2026-04-15 is a research digest covering five papers in the fast NeRF arc and focusing on how Neural Radiance Fields progressed from hours-per-scene to minutes-per-scene between 2021 and 2022.</data>
  <data key="d3">chunk-ec770f62777c513047108cb79ba7aa75</data>
  <data key="d4">examples/demo-corpus/data/research/daily/2026-04-15/digest.md</data>
  <data key="d5">1778876604</data>
  <data key="d6"></data>
</node>
<node id="360 Benchmark">
  <data key="d0">360 Benchmark</data>
  <data key="d1">data</data>
  <data key="d2">360 Benchmark is the benchmark introduced by Mip-NeRF 360 and is described as the default scene set used by the splatting community.</data>
  <data key="d3">chunk-ec770f62777c513047108cb79ba7aa75</data>
  <data key="d4">examples/demo-corpus/data/research/daily/2026-04-15/digest.md</data>
  <data key="d5">1778876604</data>
  <data key="d6"></data>
</node>
<node id="svox2">
  <data key="d0">svox2</data>
  <data key="d1">artifact</data>
  <data key="d2">svox2 is the reference implementation associated with Plenoxels and is described as a particularly clean place to study the paper's argument in code.</data>
  <data key="d3">chunk-ec770f62777c513047108cb79ba7aa75</data>
  <data key="d4">examples/demo-corpus/data/research/daily/2026-04-15/digest.md</data>
  <data key="d5">1778876604</data>
  <data key="d6"></data>
</node>
<node id="4D Gaussian Splatting For Real-Time Dynamic Scene Rendering">
  <data key="d0">4D Gaussian Splatting For Real-Time Dynamic Scene Rendering</data>
  <data key="d1">content</data>
  <data key="d2">4D Gaussian Splatting For Real-Time Dynamic Scene Rendering is a paper dated 2023-10-12 that presents 4D-GS for real-time rendering of dynamic scenes.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876655</data>
  <data key="d6"></data>
</node>
<node id="4D-GS">
  <data key="d0">4D-GS</data>
  <data key="d1">method</data>
  <data key="d2">4D-GS is a method for time-varying scenes that pairs a canonical set of 3D Gaussians with a compact spatio-temporal field that deforms them at each timestamp.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876657</data>
  <data key="d6"></data>
</node>
<node id="Canonical Set of 3D Gaussians">
  <data key="d0">Canonical Set of 3D Gaussians</data>
  <data key="d1">artifact</data>
  <data key="d2">Canonical Set of 3D Gaussians is the shared Gaussian representation used across time in 4D-GS.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876657</data>
  <data key="d6"></data>
</node>
<node id="Spatio-Temporal Field">
  <data key="d0">Spatio-Temporal Field</data>
  <data key="d1">concept</data>
  <data key="d2">Spatio-Temporal Field is a compact field in 4D-GS that deforms shared Gaussians at each timestamp.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876657</data>
  <data key="d6"></data>
</node>
<node id="Temporal Coordinate">
  <data key="d0">Temporal Coordinate</data>
  <data key="d1">data</data>
  <data key="d2">Temporal Coordinate is the time input used to condition deformation prediction in 4D-GS.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876657</data>
  <data key="d6"></data>
</node>
<node id="Decomposed Neural Voxel Grid">
  <data key="d0">Decomposed Neural Voxel Grid</data>
  <data key="d1">method</data>
  <data key="d2">Decomposed Neural Voxel Grid is the implementation of the deformation field, using structured planar components to encode a 4D function efficiently.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876657</data>
  <data key="d6"></data>
</node>
<node id="Orthogonal Planar Projections">
  <data key="d0">Orthogonal Planar Projections</data>
  <data key="d1">concept</data>
  <data key="d2">Orthogonal Planar Projections are three planar projections used within the decomposed neural voxel grid to encode the 4D function.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Feature Planes">
  <data key="d0">Feature Planes</data>
  <data key="d1">artifact</data>
  <data key="d2">Feature Planes are planar features in the decomposed neural voxel grid that help encode the 4D function.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Lightweight MLP">
  <data key="d0">Lightweight MLP</data>
  <data key="d1">method</data>
  <data key="d2">Lightweight MLP is the decoder that maps grid features to per-Gaussian deformations.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Per-Gaussian Deformations">
  <data key="d0">Per-Gaussian Deformations</data>
  <data key="d1">concept</data>
  <data key="d2">Per-Gaussian Deformations are predicted changes in position, rotation, and scale for each Gaussian.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Dynamic Scene Benchmarks">
  <data key="d0">Dynamic Scene Benchmarks</data>
  <data key="d1">data</data>
  <data key="d2">Dynamic Scene Benchmarks are the evaluation benchmarks on which the method is reported to achieve competitive or better reconstruction quality.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Prior Dynamic NeRFs">
  <data key="d0">Prior Dynamic NeRFs</data>
  <data key="d1">method</data>
  <data key="d2">Prior Dynamic NeRFs are earlier dynamic neural radiance field methods used as reconstruction quality baselines.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="82 FPS">
  <data key="d0">82 FPS</data>
  <data key="d1">data</data>
  <data key="d2">82 FPS is the reported rendering speed achieved by the method at 800×800 on an RTX 3090.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="800×800">
  <data key="d0">800×800</data>
  <data key="d1">data</data>
  <data key="d2">800×800 is the rendering resolution at which the method sustains 82 FPS.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Anisotropic 4D XYZT Gaussians">
  <data key="d0">Anisotropic 4D XYZT Gaussians</data>
  <data key="d1">artifact</data>
  <data key="d2">Anisotropic 4D XYZT Gaussians are explicit primitives used by 4D-Rotor Gaussian Splatting to represent motion.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Dynamic Radiance Fields">
  <data key="d0">Dynamic Radiance Fields</data>
  <data key="d1">concept</data>
  <data key="d2">Dynamic Radiance Fields are time-varying scene representations that the discussed Gaussian methods render.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Released Code">
  <data key="d0">Released Code</data>
  <data key="d1">artifact</data>
  <data key="d2">Released Code is the codebase described as a common reference implementation for dynamic Gaussian rendering methods.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Princeton-VL">
  <data key="d0">Princeton-VL</data>
  <data key="d1">organization</data>
  <data key="d2">Princeton-VL is the organization or project namespace associated with the DROID-SLAM GitHub repository.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Princeton-VL/DROID-SLAM">
  <data key="d0">Princeton-VL/DROID-SLAM</data>
  <data key="d1">artifact</data>
  <data key="d2">Princeton-VL/DROID-SLAM is a mirrored GitHub repository entry that contains the README text for the upstream DROID-SLAM project and notes that code is not included in the mirror.&lt;SEP&gt;Princeton-VL/DROID-SLAM is the official PyTorch repository implementation of DROID-SLAM and provides trained weights, differentiable bundle adjustment CUDA kernels, and evaluation scripts.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7&lt;SEP&gt;chunk-a57ecf4979daf463711507fe01462548</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/about.md</data>
  <data key="d5">1778876675</data>
  <data key="d6"></data>
</node>
<node id="DROID-SLAM: Deep Visual SLAM for Monocular, Stereo, and RGB-D Cameras">
  <data key="d0">DROID-SLAM: Deep Visual SLAM for Monocular, Stereo, and RGB-D Cameras</data>
  <data key="d1">content</data>
  <data key="d2">DROID-SLAM: Deep Visual SLAM for Monocular, Stereo, and RGB-D Cameras is the canonical paper associated with the project and is cited in the README.&lt;SEP&gt;DROID-SLAM: Deep Visual SLAM for Monocular, Stereo, and RGB-D Cameras is the paper associated with the repository and is cited as the contextual source for the implementation.&lt;SEP&gt;DROID-SLAM: Deep Visual SLAM for Monocular, Stereo, and RGB-D Cameras is a paper describing the DROID-SLAM system and its architecture, training setup, and empirical performance.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7&lt;SEP&gt;chunk-a57ecf4979daf463711507fe01462548&lt;SEP&gt;chunk-7411808cb359d1b718d660e9dbd2a39e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/about.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2108-10869/paper.md</data>
  <data key="d5">1778876760</data>
  <data key="d6"></data>
</node>
<node id="Advances in Neural Information Processing Systems">
  <data key="d0">Advances in Neural Information Processing Systems</data>
  <data key="d1">organization</data>
  <data key="d2">Advances in Neural Information Processing Systems is the journal or publication venue named in the DROID-SLAM paper citation.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="BSD-3-Clause">
  <data key="d0">BSD-3-Clause</data>
  <data key="d1">content</data>
  <data key="d2">BSD-3-Clause is the license identified for the mirrored DROID-SLAM repository entry.&lt;SEP&gt;BSD-3-Clause is the license under which the repository mirror is described as being available.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7&lt;SEP&gt;chunk-a57ecf4979daf463711507fe01462548</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/about.md</data>
  <data key="d5">1778876676</data>
  <data key="d6"></data>
</node>
<node id="Sequence Length">
  <data key="d0">Sequence Length</data>
  <data key="d1">data</data>
  <data key="d2">Sequence Length is the number of frames over time that would cause linear scaling in a per-frame representation.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Per-Scene Memory Footprint">
  <data key="d0">Per-Scene Memory Footprint</data>
  <data key="d1">concept</data>
  <data key="d2">Per-Scene Memory Footprint is the storage cost measure that scales roughly with deformation grid size in the method.</data>
  <data key="d3">chunk-cb7662ca60286f5c929b6bb92d667dfd</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="RTX-3090 GPUs">
  <data key="d0">RTX-3090 GPUs</data>
  <data key="d1">artifact</data>
  <data key="d2">RTX-3090 GPUs are the specific GPUs named as the hardware used for DROID-SLAM training, with four units used in the described setup.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="droid.pth">
  <data key="d0">droid.pth</data>
  <data key="d1">data</data>
  <data key="d2">droid.pth is the model file that users are instructed to download before running DROID-SLAM demos.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Google Drive">
  <data key="d0">Google Drive</data>
  <data key="d1">organization</data>
  <data key="d2">Google Drive is the download source referenced for the droid.pth model file.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Sample Videos">
  <data key="d0">Sample Videos</data>
  <data key="d1">data</data>
  <data key="d2">Sample Videos are example input data that can be downloaded with a provided script for running DROID-SLAM demos.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Calibration File">
  <data key="d0">Calibration File</data>
  <data key="d1">data</data>
  <data key="d2">Calibration File is the required input specification for running DROID-SLAM on custom data, containing camera parameters in a defined numeric format.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876658</data>
  <data key="d6"></data>
</node>
<node id="Asynchronous Inference">
  <data key="d0">Asynchronous Inference</data>
  <data key="d1">method</data>
  <data key="d2">Asynchronous Inference is a DROID-SLAM execution mode in which the frontend and backend run in separate Python processes.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="Multi-GPU Inference">
  <data key="d0">Multi-GPU Inference</data>
  <data key="d1">method</data>
  <data key="d2">Multi-GPU inference is an evaluation setup in which frontend and backend processes are assigned to different CUDA devices.&lt;SEP&gt;Multi-GPU Inference is a DROID-SLAM execution mode that assigns frontend and backend processes to different devices.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7&lt;SEP&gt;chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="TUM">
  <data key="d0">TUM</data>
  <data key="d1">data</data>
  <data key="d2">TUM is a dataset used for evaluation and can be run on a 1080Ti GPU.&lt;SEP&gt;TUM is a dataset supported by the DROID-SLAM evaluation scripts and can be run on a 1080Ti according to the README.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7&lt;SEP&gt;chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="ETH3D-SLAM">
  <data key="d0">ETH3D-SLAM</data>
  <data key="d1">data</data>
  <data key="d2">ETH3D-SLAM is a dataset benchmark included in the provided evaluation scripts and requires 24G of memory.&lt;SEP&gt;ETH3D-SLAM is a dataset supported by the DROID-SLAM evaluation scripts and is stated to require 24G of memory.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7&lt;SEP&gt;chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="1080Ti">
  <data key="d0">1080Ti</data>
  <data key="d1">artifact</data>
  <data key="d2">1080Ti is a GPU on which EuRoC and TUM evaluations can be run.&lt;SEP&gt;1080Ti is the GPU model named in the README as sufficient hardware for running EuRoC and TUM evaluation.</data>
  <data key="d3">chunk-833bec7f18854880457df56d1a16dbb7&lt;SEP&gt;chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="Evaluation Scripts">
  <data key="d0">Evaluation Scripts</data>
  <data key="d1">content</data>
  <data key="d2">Evaluation scripts are provided for running benchmarks on the TartanAir, EuRoC, TUM, and ETH3D-SLAM datasets.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="ETH3D">
  <data key="d0">ETH3D</data>
  <data key="d1">data</data>
  <data key="d2">ETH3D is a dataset of RGB-D sequences used for evaluation and result parsing.&lt;SEP&gt;ETH3D is a benchmark on which DROID-SLAM is described as robust while classical baselines suffer catastrophic tracking failures.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77&lt;SEP&gt;chunk-7411808cb359d1b718d660e9dbd2a39e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2108-10869/paper.md</data>
  <data key="d5">1778876762</data>
  <data key="d6"></data>
</node>
<node id="Asynchronous Mode">
  <data key="d0">Asynchronous Mode</data>
  <data key="d1">method</data>
  <data key="d2">Asynchronous mode is an evaluation setting enabled with `--asynchronous` in which the frontend and backend run in separate Python processes and results are typically better but not deterministic.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="Frontend Process">
  <data key="d0">Frontend Process</data>
  <data key="d1">other</data>
  <data key="d2">The frontend process is one of the separate Python processes used in asynchronous evaluation and can be assigned a specific device.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="Backend Process">
  <data key="d0">Backend Process</data>
  <data key="d1">other</data>
  <data key="d2">The backend process is one of the separate Python processes used in asynchronous evaluation and can be assigned a specific device.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="24G of Memory">
  <data key="d0">24G of Memory</data>
  <data key="d1">data</data>
  <data key="d2">24G of memory is the memory requirement stated for running the TartanAir and ETH3D-SLAM datasets.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="Covisibility">
  <data key="d0">Covisibility</data>
  <data key="d1">concept</data>
  <data key="d2">Covisibility is computed between all pairs of frames on the first training run, may take several hours, and is cached for future runs.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="4x3090 RTX GPUs">
  <data key="d0">4x3090 RTX GPUs</data>
  <data key="d1">artifact</data>
  <data key="d2">4x3090 RTX GPUs are the hardware configuration used for training, which takes approximately one week.</data>
  <data key="d3">chunk-589b580dce9f23cba1db6f4f68a4ae77</data>
  <data key="d4">examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="evo">
  <data key="d0">evo</data>
  <data key="d1">content</data>
  <data key="d2">evo is an evaluation tool additionally used by the model workflow.&lt;SEP&gt;evo is an evaluation tool used for model evaluation.</data>
