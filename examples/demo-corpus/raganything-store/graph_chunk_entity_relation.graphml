<edge source="Scaffold-GS" target="View-Adaptive Rendering">
  <data key="d7">1.0</data>
  <data key="d8">Scaffold-GS achieves view-adaptive rendering by allowing the same anchor to produce different splat patterns from different viewing angles.</data>
