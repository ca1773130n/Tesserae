  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Broom2">
  <data key="d0">Broom2</data>
  <data key="d1">content</data>
  <data key="d2">broom2 is a HyperNeRF scene under `virg` used as an example for point-cloud preparation and training.</data>
  <data key="d3">chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
