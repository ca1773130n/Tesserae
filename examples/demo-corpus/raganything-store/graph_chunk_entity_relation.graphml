  <data key="d6"></data>
</node>
<node id="Pose Coordinate System">
  <data key="d0">Pose Coordinate System</data>
  <data key="d1">concept</data>
  <data key="d2">Pose Coordinate System is the local camera coordinate convention in which the X axis points right, the Y axis points upward, and the Z axis points backward from the image perspective.</data>
  <data key="d3">chunk-45d73dd21f95946d74e1b943beb1d384</data>
  <data key="d4">examples/demo-corpus/data/research/repos/bmild-nerf/readme.md</data>
  <data key="d5">1778876879</data>
  <data key="d6"></data>
</node>
