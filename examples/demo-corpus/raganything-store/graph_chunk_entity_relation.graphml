  <data key="d3">chunk-67aca36ec8eb49d9f01fa3055f69d8fd</data>
  <data key="d4">examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876503</data>
  <data key="d6"></data>
</node>
<node id="Compiler">
  <data key="d0">Compiler</data>
  <data key="d1">artifact</data>
  <data key="d2">The Compiler is part of the build toolchain and must be updated in tandem with CUDA for compatibility.</data>
  <data key="d3">chunk-67aca36ec8eb49d9f01fa3055f69d8fd</data>
  <data key="d4">examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876503</data>
  <data key="d6"></data>
</node>
<node id="Build Folder">
  <data key="d0">Build Folder</data>
  <data key="d1">artifact</data>
  <data key="d2">The Build Folder is the generated build directory that should be deleted after each troubleshooting step so CMake can regenerate it.</data>
  <data key="d3">chunk-67aca36ec8eb49d9f01fa3055f69d8fd</data>
  <data key="d4">examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876503</data>
  <data key="d6"></data>
</node>
<node id="CMake">
  <data key="d0">CMake</data>
  <data key="d1">artifact</data>
  <data key="d2">CMake is a required build tool with version 3.21 or higher used to build Instant-NGP.&lt;SEP&gt;CMake is the build system generator used for compiling Instant-NGP and regenerating the build folder.</data>
  <data key="d3">chunk-67aca36ec8eb49d9f01fa3055f69d8fd&lt;SEP&gt;chunk-5b9702cfd82aaa0f9d50ba7409bbecf8</data>
