  <data key="d0">3x4 NumPy Arrays</data>
  <data key="d1">data</data>
  <data key="d2">3x4 NumPy Arrays are the format used to store poses as camera-to-world transformation matrices.</data>
  <data key="d3">chunk-45d73dd21f95946d74e1b943beb1d384</data>
  <data key="d4">examples/demo-corpus/data/research/repos/bmild-nerf/readme.md</data>
  <data key="d5">1778876879</data>
  <data key="d6"></data>
</node>
