  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2106-10689/paper.md</data>
  <data key="d12">1778874757</data>
  <data key="d13"></data>
</edge>
<edge source="NeRF" target="UNISURF">
  <data key="d7">1.0</data>
  <data key="d8">UNISURF unifies radiance-field volume rendering with implicit-surface reconstruction and is explicitly presented in relation to NeRF.</data>
