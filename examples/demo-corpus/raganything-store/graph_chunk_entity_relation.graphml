  <data key="d6"></data>
</node>
<node id="Successors">
  <data key="d0">Successors</data>
  <data key="d1">content</data>
  <data key="d2">Successors are later works following LRM in the large reconstruction model line that continue questioning the necessity of per-scene optimisation.</data>
  <data key="d3">chunk-a4716f0532d6b5d940a3893a269cfdc9</data>
  <data key="d4">examples/demo-corpus/data/research/weekly/2026-W17/synthesis.md</data>
