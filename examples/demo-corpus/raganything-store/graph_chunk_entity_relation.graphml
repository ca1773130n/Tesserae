  <data key="d0">Amos Gropp</data>
  <data key="d1">person</data>
  <data key="d2">Amos Gropp is an author of Implicit Geometric Regularization for Learning Shapes.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
<node id="Lior Yariv">
  <data key="d0">Lior Yariv</data>
  <data key="d1">person</data>
  <data key="d2">Lior Yariv is an author of Implicit Geometric Regularization for Learning Shapes.&lt;SEP&gt;Lior Yariv is an author of Volume Rendering of Neural Implicit Surfaces.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735&lt;SEP&gt;chunk-62f6aaf4d349907fedafca12c9a53bdb</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2106-12052/paper.md</data>
  <data key="d5">1778876783</data>
  <data key="d6"></data>
</node>
