</node>
<node id="Greg Shakhnarovich">
  <data key="d0">Greg Shakhnarovich</data>
  <data key="d1">person</data>
  <data key="d2">Greg Shakhnarovich is an author of the Instant3D paper.</data>
  <data key="d3">chunk-22bc14784620637c470939b2097cd200</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md</data>
  <data key="d5">1778875862</data>
  <data key="d6"></data>
</node>
<node id="Sparse-View Generation">
  <data key="d0">Sparse-View Generation</data>
  <data key="d1">method</data>
  <data key="d2">Sparse-View Generation is the first stage of Instant3D that produces four structured and view-consistent images of an object from text.</data>
  <data key="d3">chunk-22bc14784620637c470939b2097cd200</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md</data>
  <data key="d5">1778875862</data>
  <data key="d6"></data>
</node>
<node id="Score Distillation">
  <data key="d0">Score Distillation</data>
  <data key="d1">method</data>
  <data key="d2">Score Distillation is a class of Text-to-3D methods characterized in the paper as relying on slow per-prompt optimization.&lt;SEP&gt;Score Distillation is a 3D generation method family that DreamGaussian accelerates by replacing the implicit RadianceField representation.</data>
  <data key="d3">chunk-22bc14784620637c470939b2097cd200&lt;SEP&gt;chunk-e8d7bbefe39a52948bd9d7195856ac2b</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2309-16653/paper.md</data>
  <data key="d5">1778876451</data>
  <data key="d6"></data>
</node>
<node id="Transformer Architecture">
  <data key="d0">Transformer Architecture</data>
  <data key="d1">method</data>
  <data key="d2">Transformer Architecture is the model architecture used by the sparse-view reconstructor in Instant3D.</data>
  <data key="d3">chunk-22bc14784620637c470939b2097cd200</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md</data>
  <data key="d5">1778875862</data>
  <data key="d6"></data>
</node>
<node id="Janus Artefacts">
  <data key="d0">Janus Artefacts</data>
  <data key="d1">concept</data>
  <data key="d2">Janus Artefacts are multi-view inconsistency failures associated with single-image optimization methods that Instant3D aims to avoid.</data>
  <data key="d3">chunk-22bc14784620637c470939b2097cd200</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md</data>
  <data key="d5">1778875862</data>
  <data key="d6"></data>
</node>
<node id="3D Asset">
  <data key="d0">3D Asset</data>
  <data key="d1">artifact</data>
  <data key="d2">3D Asset is the output generated by Instant3D in roughly twenty seconds.</data>
  <data key="d3">chunk-22bc14784620637c470939b2097cd200</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md</data>
  <data key="d5">1778875862</data>
  <data key="d6"></data>
</node>
<node id="GaussianSplatting">
  <data key="d0">GaussianSplatting</data>
  <data key="d1">method</data>
  <data key="d2">GaussianSplatting is an alternative representation mentioned as a common substitution for a radiance field predictor in later work.&lt;SEP&gt;GaussianSplatting is the method implemented by the gsplat library and named in the paper metadata as the method associated with the supplement.&lt;SEP&gt;GaussianSplatting is a method listed in the paper metadata and is the Gaussian splatting approach extended by the paper to dynamic scenes.&lt;SEP&gt;GaussianSplatting is a representation head style that downstream pipelines can use in place of TripoSR's implicit output.</data>
  <data key="d3">chunk-22bc14784620637c470939b2097cd200&lt;SEP&gt;chunk-3243555eac5ed46cea7fe8cead1666bc&lt;SEP&gt;chunk-cb7662ca60286f5c929b6bb92d667dfd&lt;SEP&gt;chunk-da7ad32a7899b18880ae81f4444362ce</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2312-02121/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2310-08528/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2403-02151/paper.md</data>
  <data key="d5">1778876872</data>
  <data key="d6"></data>
</node>
