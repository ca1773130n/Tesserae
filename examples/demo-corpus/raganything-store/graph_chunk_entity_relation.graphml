  <data key="d6"></data>
</node>
<node id="A6000">
  <data key="d0">A6000</data>
  <data key="d1">artifact</data>
  <data key="d2">A6000 is the hardware contained in the reference machine used for the reported evaluation time.&lt;SEP&gt;A6000 is the GPU contained in the reference machine used for the reported process timing.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e&lt;SEP&gt;chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
