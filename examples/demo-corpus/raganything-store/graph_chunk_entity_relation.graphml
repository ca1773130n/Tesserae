  <data key="d6"></data>
</node>
<node id="Tiny-CUDA-NN Fused MLP Runtime">
  <data key="d0">Tiny-CUDA-NN Fused MLP Runtime</data>
  <data key="d1">method</data>
  <data key="d2">Tiny-CUDA-NN Fused MLP Runtime is a fused MLP runtime introduced by NVlabs/instant-ngp that, together with the encoding, reduced NeRF training time from hours to seconds.</data>
  <data key="d3">chunk-1ce2165eaaf1422a9b02235e41e20e20</data>
  <data key="d4">examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/about.md</data>
  <data key="d5">1778876670</data>
  <data key="d6"></data>
</node>
<node id="Instant-NGP Viewer">
  <data key="d0">Instant-NGP Viewer</data>
  <data key="d1">artifact</data>
  <data key="d2">Instant-NGP Viewer is a viewer introduced by NVlabs/instant-ngp that made interactive radiance-field editing practical.</data>
  <data key="d3">chunk-1ce2165eaaf1422a9b02235e41e20e20</data>
  <data key="d4">examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/about.md</data>
  <data key="d5">1778876670</data>
  <data key="d6"></data>
</node>
