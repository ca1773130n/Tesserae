  <data key="d0">valid_paths.json.zip</data>
  <data key="d1">data</data>
  <data key="d2">valid_paths.json.zip is a zipped JSON file that the preliminary training instructions direct users to download and unzip.</data>
  <data key="d3">chunk-0d057f3bc5fa56c4a6477fe9f9195f8b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/readme.md</data>
