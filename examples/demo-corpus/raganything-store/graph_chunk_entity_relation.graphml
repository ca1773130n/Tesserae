  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Synthetic Scenes">
  <data key="d0">Synthetic Scenes</data>
  <data key="d1">concept</data>
  <data key="d2">Synthetic Scenes are a set of scenes targeted by an automated train-and-evaluate task configuration.&lt;SEP&gt;Synthetic scenes are training scenes such as bouncingballs that are trained with the DNeRF data layout and configuration.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941&lt;SEP&gt;chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Forward-Facing Scenes">
  <data key="d0">Forward-Facing Scenes</data>
  <data key="d1">data</data>
  <data key="d2">Forward-Facing Scenes are a set of scenes handled by a dedicated autotune task configuration.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
