  <data key="d0">Omnidata</data>
  <data key="d1">method</data>
  <data key="d2">Omnidata is a pretrained model required for depth and normal prediction in image-conditioned 3D generation.</data>
  <data key="d3">chunk-cee14ff0001178656f392a3bf199e70c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875661</data>
  <data key="d6"></data>
</node>
