  <data key="d0">Cut Roasted Beef</data>
  <data key="d1">content</data>
  <data key="d2">cut_roasted_beef is a DyNeRF scene used as an example workflow for frame extraction, point-cloud generation, point-cloud downsampling, and training.</data>
  <data key="d3">chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
