  <data key="d1">artifact</data>
  <data key="d2">Graphdeco-Inria/Gaussian-Splatting is the open-source repository for the INRIA reference implementation of the method.</data>
  <data key="d3">chunk-d445282e0f2225e2a32ef51280563a09</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2308-04079/paper.md</data>
  <data key="d5">1778876014</data>
  <data key="d6"></data>
</node>
<node id="NeRF-Style Methods">
  <data key="d0">NeRF-Style Methods</data>
  <data key="d1">method</data>
  <data key="d2">NeRF-Style Methods are prior radiance field methods that ray-march through an implicit volume and must sample along empty regions of a ray.</data>
  <data key="d3">chunk-d445282e0f2225e2a32ef51280563a09</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2308-04079/paper.md</data>
  <data key="d5">1778876014</data>
  <data key="d6"></data>
</node>
<node id="Densification And Pruning Schedule">
  <data key="d0">Densification And Pruning Schedule</data>
  <data key="d1">method</data>
  <data key="d2">Densification And Pruning Schedule is a training procedure that clones, splits, and removes Gaussian primitives while adapting anisotropic covariance to local geometry.</data>
  <data key="d3">chunk-d445282e0f2225e2a32ef51280563a09</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2308-04079/paper.md</data>
  <data key="d5">1778876014</data>
  <data key="d6"></data>
</node>
<node id="Visibility-Aware Tile Rasteriser">
  <data key="d0">Visibility-Aware Tile Rasteriser</data>
  <data key="d1">method</data>
  <data key="d2">Visibility-Aware Tile Rasteriser is a fast, GPU-friendly rasterisation method with a closed-form backward pass that accelerates training and inference.</data>
  <data key="d3">chunk-d445282e0f2225e2a32ef51280563a09</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2308-04079/paper.md</data>
  <data key="d5">1778876014</data>
  <data key="d6"></data>
</node>
<node id="Explicit-Primitive Novel-View Synthesis">
  <data key="d0">Explicit-Primitive Novel-View Synthesis</data>
  <data key="d1">concept</data>
  <data key="d2">Explicit-Primitive Novel-View Synthesis is the formulation of novel-view synthesis in which scenes are represented with explicit primitives rather than implicit volumes.</data>
  <data key="d3">chunk-d445282e0f2225e2a32ef51280563a09</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2308-04079/paper.md</data>
  <data key="d5">1778876014</data>
  <data key="d6"></data>
</node>
