<node id="HyperNeRF Dataset">
  <data key="d0">HyperNeRF Dataset</data>
  <data key="d1">data</data>
  <data key="d2">HyperNeRF Dataset is a downloadable set of scenes for real dynamic scenes that can be organized as Nerfies.</data>
  <data key="d3">chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Plenoptic Dataset">
  <data key="d0">Plenoptic Dataset</data>
  <data key="d1">data</data>
  <data key="d2">Plenoptic Dataset is a downloadable dataset for dynamic scenes whose videos should be converted into extracted frames to save memory.</data>
  <data key="d3">chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Multipleviews Scenes">
  <data key="d0">Multipleviews Scenes</data>
  <data key="d1">concept</data>
  <data key="d2">Multipleviews Scenes are scenes organized by camera folders and image frames for training a user-owned dataset.</data>
  <data key="d3">chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="multipleviewprogress.sh">
  <data key="d0">multipleviewprogress.sh</data>
  <data key="d1">artifact</data>
  <data key="d2">multipleviewprogress.sh is a provided script used to generate pose and point-cloud related data for a multipleviews dataset.</data>
  <data key="d3">chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Poses">
  <data key="d0">Poses</data>
  <data key="d1">data</data>
  <data key="d2">Poses are related data generated for multipleviews datasets after running multipleviewprogress.sh.</data>
  <data key="d3">chunk-e94987ca7ac98962142f83ef53476d0b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Point Clouds">
  <data key="d0">Point Clouds</data>
  <data key="d1">data</data>
  <data key="d2">Point Clouds are generated or downsampled data used in dataset preparation and training workflows.</data>
