  <data key="d6"></data>
</node>
<node id="Robust NeRF Training">
  <data key="d0">Robust NeRF Training</data>
  <data key="d1">method</data>
  <data key="d2">Robust NeRF Training is a later NeRF training approach that reuses the transient-uncertainty idea to ignore inconsistent observations.</data>
  <data key="d3">chunk-501dafee6515bd66912047d0b36d43f9</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2008-02268/paper.md</data>
  <data key="d5">1778874882</data>
  <data key="d6"></data>
</node>
<node id="Controlled Laboratory Capture">
  <data key="d0">Controlled Laboratory Capture</data>
  <data key="d1">concept</data>
  <data key="d2">Controlled Laboratory Capture is the controlled capture regime beyond which NeRF-W pushes NeRF.</data>
