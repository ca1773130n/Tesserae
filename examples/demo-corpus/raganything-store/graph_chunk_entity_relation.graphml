<node id="Huggingface-CLI Login">
  <data key="d0">Huggingface-CLI Login</data>
  <data key="d1">method</data>
  <data key="d2">Huggingface-CLI Login is the command-line authentication method required to log in before using DeepFloyd-IF.</data>
  <data key="d3">chunk-b0ea2d1fff273acbdf62338200407400</data>
