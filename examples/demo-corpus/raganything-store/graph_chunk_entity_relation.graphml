  <data key="d12">1778876607</data>
  <data key="d13"></data>
</edge>
<edge source="NeRF" target="Aliasing">
  <data key="d7">1.0</data>
  <data key="d8">NeRF produces aliasing when training and test images observe a scene at different resolutions because each pixel is rendered with a single infinitesimally thin ray.</data>
  <data key="d9">rendering error,sampling problem</data>
  <data key="d10">chunk-24800bbb3bf5dc8182a3f3b86a0d5dad</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2103-13415/paper.md</data>
  <data key="d12">1778875182</data>
  <data key="d13"></data>
</edge>
