  <data key="d0">preprocess_image.py</data>
  <data key="d1">artifact</data>
  <data key="d2">preprocess_image.py is a preprocessing script that prepares an input image and exports RGBA, depth, and normal image files for image-conditioned 3D generation.</data>
  <data key="d3">chunk-6fbd6ef7fa46c0ba5c1daac3eb1cafc5</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875661</data>
  <data key="d6"></data>
</node>
<node id="360 Degree Video">
  <data key="d0">360 Degree Video</data>
  <data key="d1">artifact</data>
  <data key="d2">360 Degree Video is a test output that can be exported after training is finished.</data>
  <data key="d3">chunk-6fbd6ef7fa46c0ba5c1daac3eb1cafc5</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875661</data>
  <data key="d6"></data>
</node>
<node id="NeRF Checkpoint">
  <data key="d0">NeRF Checkpoint</data>
  <data key="d1">data</data>
  <data key="d2">NeRF Checkpoint is a saved checkpoint file that can be provided to initialize DMTet finetuning.</data>
  <data key="d3">chunk-6fbd6ef7fa46c0ba5c1daac3eb1cafc5</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875661</data>
  <data key="d6"></data>
</node>
<node id="CUDA OOM">
  <data key="d0">CUDA OOM</data>
  <data key="d1">concept</data>
  <data key="d2">CUDA OOM is an out-of-memory condition that can occur during Vanilla NeRF training and may be mitigated by reducing sampling steps.</data>
  <data key="d3">chunk-6fbd6ef7fa46c0ba5c1daac3eb1cafc5</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875661</data>
  <data key="d6"></data>
</node>
<node id="Guidance Images">
  <data key="d0">Guidance Images</data>
  <data key="d1">artifact</data>
  <data key="d2">Guidance Images are debug outputs that can be saved for debugging purposes, but they slow training and consume substantial disk space.&lt;SEP&gt;Guidance Images are debugging outputs that can be saved during training and are stored in a guidance subdirectory.</data>
  <data key="d3">chunk-6fbd6ef7fa46c0ba5c1daac3eb1cafc5&lt;SEP&gt;chunk-89b96bffec912e64ed752226976c3822</data>
