  <data key="d5">1778876010</data>
  <data key="d6"></data>
</node>
<node id="Text-to-3D Line">
  <data key="d0">Text-to-3D Line</data>
  <data key="d1">concept</data>
  <data key="d2">The text-to-3D line is the research direction focused on generating 3D content from text and is represented in the text by works such as DreamFusion and Magic3D.</data>
  <data key="d3">chunk-7d4bb138a75a3adf4eebfac8bdf1be29</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2303-11328/paper.md</data>
