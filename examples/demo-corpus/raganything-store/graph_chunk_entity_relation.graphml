<node id="XYZT Domain">
  <data key="d0">XYZT Domain</data>
  <data key="d1">concept</data>
  <data key="d2">XYZT Domain is the joint spatial-temporal domain over which 4DRotorGS defines anisotropic 4D Gaussians.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876987</data>
  <data key="d6"></data>
</node>
<node id="Cvlab-Columbia/Zero123">
  <data key="d0">Cvlab-Columbia/Zero123</data>
  <data key="d1">artifact</data>
  <data key="d2">Cvlab-Columbia/Zero123 is a repository that is described as the official release of Zero-1-to-3: Zero-shot One Image to 3D Object and provides a checkpoint and inference scripts.</data>
  <data key="d3">chunk-c47e36db5dfb4966f1d4d610b06ac6bc</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/about.md</data>
  <data key="d5">1778876990</data>
  <data key="d6"></data>
</node>
<node id="Liu Et Al., 2023">
  <data key="d0">Liu Et Al., 2023</data>
  <data key="d1">content</data>
  <data key="d2">Liu Et Al., 2023 is the cited authorship and publication year associated with Zero-1-to-3: Zero-shot One Image to 3D Object.</data>
  <data key="d3">chunk-c47e36db5dfb4966f1d4d610b06ac6bc</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/about.md</data>
  <data key="d5">1778876990</data>
  <data key="d6"></data>
</node>
<node id="Viewpoint-Conditioned Novel View Synthesis">
  <data key="d0">Viewpoint-Conditioned Novel View Synthesis</data>
  <data key="d1">method</data>
  <data key="d2">Viewpoint-Conditioned Novel View Synthesis is the task performed from a single image by the fine-tuned Stable Diffusion model in Zero-1-to-3.</data>
  <data key="d3">chunk-c47e36db5dfb4966f1d4d610b06ac6bc</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/about.md</data>
  <data key="d5">1778876990</data>
  <data key="d6"></data>
</node>
<node id="3D">
  <data key="d0">3D</data>
  <data key="d1">concept</data>
  <data key="d2">3D is the output domain targeted by the SDS lifting process in Zero-1-to-3.</data>
  <data key="d3">chunk-c47e36db5dfb4966f1d4d610b06ac6bc</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/about.md</data>
  <data key="d5">1778876990</data>
  <data key="d6"></data>
</node>
<node id="Inference Scripts">
  <data key="d0">Inference Scripts</data>
  <data key="d1">artifact</data>
  <data key="d2">Inference Scripts are executable resources provided by the repository for downstream use.</data>
  <data key="d3">chunk-c47e36db5dfb4966f1d4d610b06ac6bc</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/about.md</data>
  <data key="d5">1778876990</data>
  <data key="d6"></data>
</node>
