  <data key="d1">artifact</data>
  <data key="d2">Visual Studio is one of the supported software tools for building the viewers.&lt;SEP&gt;Visual Studio is referenced in Windows-specific troubleshooting for CUDA integration and MSVC-related CMake errors.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e&lt;SEP&gt;chunk-67aca36ec8eb49d9f01fa3055f69d8fd</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876504</data>
  <data key="d6"></data>
</node>
<node id="g++">
  <data key="d0">g++</data>
  <data key="d1">artifact</data>
  <data key="d2">g++ is one of the supported software tools for building the viewers.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Clang">
  <data key="d0">Clang</data>
