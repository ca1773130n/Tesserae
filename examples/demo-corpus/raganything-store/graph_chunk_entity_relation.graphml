</node>
<node id="The App">
  <data key="d0">The App</data>
  <data key="d1">artifact</data>
  <data key="d2">The app is described as using around 22 GB of VRAM, which may make it impossible to run on some GPUs.</data>
  <data key="d3">chunk-d1cb4f77562fea889c9e32a8c9b6b118</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/readme.md</data>
