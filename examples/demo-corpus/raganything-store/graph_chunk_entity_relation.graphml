  <data key="d0">r_precision.py</data>
  <data key="d1">artifact</data>
  <data key="d2">r_precision.py is a script used to test R-precision between a text prompt and an image.</data>
  <data key="d3">chunk-89b96bffec912e64ed752226976c3822</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
