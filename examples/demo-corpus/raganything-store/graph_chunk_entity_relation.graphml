  <data key="d0">Marching Cube</data>
  <data key="d1">method</data>
  <data key="d2">Marching cube is the method used to export a mesh from the trained Voxel NeRF.</data>
  <data key="d3">chunk-d1cb4f77562fea889c9e32a8c9b6b118</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/readme.md</data>
