  <data key="d6"></data>
</node>
<node id="Black Background">
  <data key="d0">Black Background</data>
  <data key="d1">concept</data>
  <data key="d2">Black Background is the default background setting that can be replaced by a white background.</data>
  <data key="d3">chunk-f03bfcd22d34d1827ec44d4dfcce42df</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Total Loss">
  <data key="d0">Total Loss</data>
  <data key="d1">concept</data>
  <data key="d2">Total Loss is the training objective whose weighting is partly influenced by SSIM through the `--lambda_dssim` argument.</data>
  <data key="d3">chunk-f03bfcd22d34d1827ec44d4dfcce42df</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Reference Machine">
  <data key="d0">Reference Machine</data>
  <data key="d1">artifact</data>
  <data key="d2">Reference Machine is the machine on which the current full evaluation process takes about 7 hours.&lt;SEP&gt;Reference Machine is the machine used as a timing baseline for the process, and it contains an A6000.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e&lt;SEP&gt;chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
