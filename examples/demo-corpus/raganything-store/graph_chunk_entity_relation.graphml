<node id="Controllable Illumination Conditions">
  <data key="d0">Controllable Illumination Conditions</data>
  <data key="d1">concept</data>
  <data key="d2">Controllable Illumination Conditions are adjustable lighting conditions supported by NeRF-W renderings.</data>
