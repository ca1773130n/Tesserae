  <data key="d0">Michael Niemeyer</data>
  <data key="d1">person</data>
  <data key="d2">Michael Niemeyer is an author of MonoSDF.</data>
  <data key="d3">chunk-39dac1db0f50be2348ba37c8912fe321</data>
