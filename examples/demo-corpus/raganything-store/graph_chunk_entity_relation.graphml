  <data key="d0">Compute Capability 7.0+</data>
  <data key="d1">data</data>
  <data key="d2">Compute Capability 7.0+ is the minimum CUDA compute capability required for the Real-Time Viewer.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Visual Studio">
