  <data key="d0">Lambda Labs</data>
  <data key="d1">organization</data>
  <data key="d2">Lambda Labs is the organization that released the image-conditioned stable diffusion checkpoint referenced in the training instructions.</data>
  <data key="d3">chunk-0d057f3bc5fa56c4a6477fe9f9195f8b&lt;SEP&gt;chunk-d1cb4f77562fea889c9e32a8c9b6b118</data>
