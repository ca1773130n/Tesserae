  <data key="d0">Technical Report</data>
  <data key="d1">content</data>
  <data key="d2">Technical Report is the document referenced for details about the TripoSR model architecture, training process, and comparisons.</data>
  <data key="d3">chunk-bc465068a32c3c5f3d12d7446a5843df</data>
  <data key="d4">examples/demo-corpus/data/research/repos/vast-ai-research-triposr/readme.md</data>
