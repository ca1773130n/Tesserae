<node id="Dynamic Objects">
  <data key="d0">Dynamic Objects</data>
  <data key="d1">concept</data>
  <data key="d2">Dynamic Objects are moving elements in a scene that are not supported by the repository and can lead to floaters.&lt;SEP&gt;Dynamic Objects are moving or changing scene elements in training images that can be masked away during NeRF training.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941&lt;SEP&gt;chunk-67aca36ec8eb49d9f01fa3055f69d8fd</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876504</data>
  <data key="d6"></data>
</node>
<node id="Specularity">
  <data key="d0">Specularity</data>
  <data key="d1">concept</data>
  <data key="d2">Specularity is a scene property of shiny surfaces that can lead to floaters or poor surface quality.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874887</data>
  <data key="d6"></data>
</node>
<node id="Exposure Variations">
  <data key="d0">Exposure Variations</data>
  <data key="d1">concept</data>
  <data key="d2">Exposure Variations are changes in exposure during capture that should be minimized by locking exposure when possible.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874887</data>
  <data key="d6"></data>
</node>
<node id="Lighting Variations">
  <data key="d0">Lighting Variations</data>
  <data key="d1">concept</data>
  <data key="d2">Lighting Variations are changes in lighting, such as moving clouds outdoors, that can harm capture quality.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874887</data>
  <data key="d6"></data>
</node>
<node id="DoF Blur">
  <data key="d0">DoF Blur</data>
  <data key="d1">concept</data>
  <data key="d2">DoF Blur is a focus-related issue that is especially substantial for small objects during capture.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874887</data>
  <data key="d6"></data>
</node>
<node id="JPEG Compression Artifacts">
  <data key="d0">JPEG Compression Artifacts</data>
  <data key="d1">concept</data>
  <data key="d2">JPEG Compression Artifacts are image quality defects that may severely affect captured images.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874887</data>
  <data key="d6"></data>
</node>
<node id="Exp Activation">
  <data key="d0">Exp Activation</data>
  <data key="d1">method</data>
  <data key="d2">Exp Activation is a proposed alternative activation function that may help with the semi-transparent look issue.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874887</data>
  <data key="d6"></data>
</node>
<node id="ReLU">
  <data key="d0">ReLU</data>
  <data key="d1">method</data>
  <data key="d2">ReLU is the existing activation function proposed to be replaced by exp activation.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874887</data>
  <data key="d6"></data>
</node>
