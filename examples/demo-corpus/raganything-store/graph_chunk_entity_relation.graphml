  <data key="d0">torch-ngp</data>
  <data key="d1">artifact</data>
  <data key="d2">torch-ngp is the implementation source used for the NeRF backbone in Stable-Dreamfusion.</data>
  <data key="d3">chunk-cee14ff0001178656f392a3bf199e70c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875660</data>
  <data key="d6"></data>
</node>
<node id="Adan">
  <data key="d0">Adan</data>
  <data key="d1">method</data>
  <data key="d2">Adan is the default optimizer used in Stable-Dreamfusion.</data>
  <data key="d3">chunk-cee14ff0001178656f392a3bf199e70c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875660</data>
  <data key="d6"></data>
</node>
