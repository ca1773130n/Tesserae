<edge source="Conical Frustums" target="Integrated Positional Encoding">
  <data key="d7">1.0</data>
  <data key="d8">Each conical frustum in Mip-NeRF is encoded using Integrated Positional Encoding.</data>
  <data key="d9">encoding,representation</data>
  <data key="d10">chunk-24800bbb3bf5dc8182a3f3b86a0d5dad</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2103-13415/paper.md</data>
