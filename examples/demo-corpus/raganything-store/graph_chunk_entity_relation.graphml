</edge>
<edge source="DreamFusion" target="DreamGaussian">
  <data key="d7">2.0</data>
  <data key="d8">DreamGaussian is defined in comparison to DreamFusion by replacing DreamFusion's NeRF backbone.&lt;SEP&gt;DreamGaussian is described as roughly an order of magnitude faster than earlier implicit SDS-based methods such as DreamFusion.</data>
  <data key="d9">architectural comparison,method comparison,replacement,speed comparison</data>
  <data key="d10">chunk-d585a450d31daf1370ab99c3ececfb44&lt;SEP&gt;chunk-e8d7bbefe39a52948bd9d7195856ac2b</data>
  <data key="d11">examples/demo-corpus/data/research/repos/dreamgaussian-dreamgaussian/about.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2309-16653/paper.md</data>
  <data key="d12">1778876483</data>
  <data key="d13"></data>
</edge>
<edge source="DreamFusion" target="NeRF MLP">
  <data key="d7">1.0</data>
  <data key="d8">DreamFusion spends much of its time querying a NeRF MLP across many sampled points per ray.</data>
  <data key="d9">computation,implicit rendering</data>
  <data key="d10">chunk-e8d7bbefe39a52948bd9d7195856ac2b</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2309-16653/paper.md</data>
  <data key="d12">1778876483</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Magic123">
  <data key="d7">1.0</data>
  <data key="d8">Magic123 is described as combining the prior associated with Magic3D with another prior from the SDS line.</data>
  <data key="d9">prior combination,synthesis</data>
  <data key="d10">chunk-b3dc42246e28acdc27923c03fab11c12</data>
  <data key="d11">examples/demo-corpus/data/research/weekly/2026-W18/synthesis.md</data>
  <data key="d12">1778874520</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Two-Stage Coarse-to-Fine Pipeline">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D introduces a two-stage coarse-to-fine pipeline as its central method for text-to-3D generation.</data>
  <data key="d9">architecture,core method</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Score Distillation Sampling">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D inherits DreamFusion's Score Distillation Sampling objective as the basis for optimization.</data>
  <data key="d9">inheritance,optimization</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Radiance Field">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D uses a radiance field in its coarse first stage to reach a plausible 3D shape quickly.</data>
  <data key="d9">representation,stage one</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Triangle Mesh">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D extracts a triangle mesh from the coarse NeRF to begin the second stage.</data>
  <data key="d9">extraction,stage transition</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Textured Mesh">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D re-parameterizes the scene as a textured mesh with deformable vertex positions in stage two.</data>
  <data key="d9">representation,stage two</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Latent Diffusion Model">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D continues Score Distillation Sampling optimization against a high-resolution latent diffusion model in the second stage.</data>
  <data key="d9">high-resolution supervision,optimization</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Differentiable Rasterizer">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D uses a differentiable rasterizer to render the second-stage mesh efficiently at full latent diffusion resolution.</data>
  <data key="d9">efficiency,rendering</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="High-Quality Textured 3D Mesh">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D produces a high-quality textured 3D mesh as its end-to-end output.</data>
  <data key="d9">output,result</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Human User Study">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D is evaluated in a human user study that reports 61.7% preference for its outputs over DreamFusion.</data>
  <data key="d9">evaluation,preference</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
  <data key="d12">1778874625</data>
  <data key="d13"></data>
</edge>
<edge source="Magic3D" target="Image-Conditioned Generation">
  <data key="d7">1.0</data>
  <data key="d8">Magic3D's mesh-based second stage enables image-conditioned generation.</data>
  <data key="d9">capability,extension</data>
  <data key="d10">chunk-c0c63708e1adea212beb7d6e83516771</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2211-10440/paper.md</data>
