  <data key="d0">diffusers</data>
  <data key="d1">artifact</data>
  <data key="d2">diffusers is the implementation source used for Stable Diffusion in Stable-Dreamfusion.</data>
  <data key="d3">chunk-cee14ff0001178656f392a3bf199e70c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
