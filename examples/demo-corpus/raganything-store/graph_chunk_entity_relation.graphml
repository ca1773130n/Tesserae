  <data key="d12">1778875386</data>
  <data key="d13"></data>
</edge>
<edge source="2D Text-to-Image Prior" target="Scalar Trade-Off Parameter">
  <data key="d7">1.0</data>
  <data key="d8">The scalar trade-off parameter controls how strongly Magic123 relies on the 2D text-to-image prior.</data>
  <data key="d9">interpolation,weighting</data>
  <data key="d10">chunk-11ccc947afd3d6b02019a4d324bd68d3</data>
