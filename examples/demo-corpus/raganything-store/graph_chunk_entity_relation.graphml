  <data key="d1">data</data>
  <data key="d2">Omnidata DPT Depth V2 Checkpoint is a pretrained checkpoint file downloaded into the `pretrained/omnidata` directory.</data>
  <data key="d3">chunk-b0ea2d1fff273acbdf62338200407400</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875661</data>
  <data key="d6"></data>
</node>
<node id="Omnidata DPT Normal V2 Checkpoint">
  <data key="d0">Omnidata DPT Normal V2 Checkpoint</data>
  <data key="d1">data</data>
  <data key="d2">Omnidata DPT Normal V2 Checkpoint is a pretrained checkpoint file downloaded into the `pretrained/omnidata` directory.</data>
  <data key="d3">chunk-b0ea2d1fff273acbdf62338200407400</data>
