</node>
<node id="Implicit Geometric Regularization for Learning Shapes">
  <data key="d0">Implicit Geometric Regularization for Learning Shapes</data>
  <data key="d1">content</data>
  <data key="d2">Implicit Geometric Regularization for Learning Shapes is a paper published on 2020-02-24 that presents Implicit Geometric Regularization for fitting neural signed distance functions to raw point clouds for mesh and surface reconstruction.</data>
  <data key="d3">chunk-f6fcd8824908a999c0b58a88cfc0f735</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2002-10099/paper.md</data>
  <data key="d5">1778876528</data>
  <data key="d6"></data>
</node>
