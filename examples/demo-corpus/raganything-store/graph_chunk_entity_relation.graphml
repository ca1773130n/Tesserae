  <data key="d0">Mega-NeRF</data>
  <data key="d1">method</data>
  <data key="d2">Mega-NeRF is a subsequent radiance-field method for aerial captures that adopted the appearance-embedding approach.</data>
  <data key="d3">chunk-501dafee6515bd66912047d0b36d43f9</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2008-02268/paper.md</data>
