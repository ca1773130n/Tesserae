  <data key="d0">Arxiv-2308-04079</data>
  <data key="d1">content</data>
  <data key="d2">Arxiv-2308-04079 is the canonical paper identifier associated with the repository.</data>
  <data key="d3">chunk-a77bbc3a5c1fbf4a8a4029857b6fa01b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/about.md</data>
  <data key="d5">1778876958</data>
  <data key="d6"></data>
</node>
<node id="4DRotorGS">
  <data key="d0">4DRotorGS</data>
  <data key="d1">method</data>
  <data key="d2">4DRotorGS is a dynamic extension of 3D Gaussian Splatting that represents a time-varying scene with anisotropic 4D Gaussians over the joint XYZT domain.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876985</data>
  <data key="d6"></data>
</node>
<node id="Dynamic-Gaussian Work">
  <data key="d0">Dynamic-Gaussian Work</data>
  <data key="d1">method</data>
  <data key="d2">Dynamic-Gaussian Work refers to prior dynamic methods that typically use canonical 3D representations with implicit or explicit deformation fields.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876985</data>
  <data key="d6"></data>
</node>
<node id="Canonical 3D Representation">
  <data key="d0">Canonical 3D Representation</data>
  <data key="d1">concept</data>
  <data key="d2">Canonical 3D Representation is a persistent scene representation used by prior dynamic methods as the reference space for deformation across time.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876985</data>
  <data key="d6"></data>
</node>
<node id="Rotor Representation">
  <data key="d0">Rotor Representation</data>
  <data key="d1">method</data>
  <data key="d2">Rotor Representation is an orientation parameterisation drawn from geometric algebra that generalises quaternions from 3D rotations to four dimensions while remaining numerically stable.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876985</data>
  <data key="d6"></data>
</node>
<node id="Geometric Algebra">
  <data key="d0">Geometric Algebra</data>
  <data key="d1">concept</data>
  <data key="d2">Geometric Algebra is the mathematical framework from which the rotor representation used by 4DRotorGS is drawn.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876986</data>
  <data key="d6"></data>
</node>
<node id="Quaternion Approach">
  <data key="d0">Quaternion Approach</data>
  <data key="d1">method</data>
  <data key="d2">Quaternion Approach is the orientation approach used for 3D rotations that rotor representation generalises to four dimensions.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876986</data>
  <data key="d6"></data>
</node>
<node id="Temporal Slicing">
  <data key="d0">Temporal Slicing</data>
  <data key="d1">method</data>
  <data key="d2">Temporal Slicing is the process of taking a slice through the 4D field at rendering time to produce effective 3D Gaussians for a frame.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876986</data>
  <data key="d6"></data>
</node>
<node id="CUDA Pipeline">
  <data key="d0">CUDA Pipeline</data>
  <data key="d1">method</data>
  <data key="d2">CUDA Pipeline is the implementation pipeline used by the authors for temporal slicing and splatting, optimised alongside existing 3DGS kernels.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876986</data>
  <data key="d6"></data>
</node>
<node id="3DGS Kernels">
  <data key="d0">3DGS Kernels</data>
  <data key="d1">artifact</data>
  <data key="d2">3DGS Kernels are the existing kernels that the CUDA pipeline is optimised alongside.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876986</data>
  <data key="d6"></data>
</node>
<node id="HexPlane-Style Deformation Field">
  <data key="d0">HexPlane-Style Deformation Field</data>
  <data key="d1">method</data>
  <data key="d2">HexPlane-Style Deformation Field is the deformation mechanism used by the 4D Gaussian Splatting line of work.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876986</data>
  <data key="d6"></data>
</node>
<node id="Abrupt Motion">
  <data key="d0">Abrupt Motion</data>
  <data key="d1">concept</data>
  <data key="d2">Abrupt Motion is a type of discontinuous scene motion that canonical deformation-based formulations struggle to model smoothly.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876987</data>
  <data key="d6"></data>
</node>
<node id="Topological Changes">
  <data key="d0">Topological Changes</data>
  <data key="d1">concept</data>
  <data key="d2">Topological Changes are scene structure changes that challenge canonical deformation-based dynamic representations.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876987</data>
  <data key="d6"></data>
</node>
<node id="Emerging Or Disappearing Content">
  <data key="d0">Emerging Or Disappearing Content</data>
  <data key="d1">concept</data>
  <data key="d2">Emerging Or Disappearing Content is scene content with limited temporal extent that is difficult for smooth deformation networks to represent.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876987</data>
  <data key="d6"></data>
</node>
<node id="277 FPS">
  <data key="d0">277 FPS</data>
  <data key="d1">data</data>
  <data key="d2">277 FPS is the reported rendering speed achieved by the CUDA pipeline at the benchmark resolution on an RTX 3090.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876987</data>
  <data key="d6"></data>
</node>
<node id="583 FPS">
  <data key="d0">583 FPS</data>
  <data key="d1">data</data>
  <data key="d2">583 FPS is the reported rendering speed achieved by the CUDA pipeline at the benchmark resolution on an RTX 4090.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876987</data>
  <data key="d6"></data>
</node>
<node id="RTX 4090">
  <data key="d0">RTX 4090</data>
  <data key="d1">artifact</data>
  <data key="d2">RTX 4090 is the hardware platform on which the authors report 583 FPS at the benchmark resolution.</data>
  <data key="d3">chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876987</data>
  <data key="d6"></data>
</node>
