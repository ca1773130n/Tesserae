  <data key="d0">3DGS Training</data>
  <data key="d1">method</data>
  <data key="d2">3DGS training is the training workflow in Nerfstudio that uses Gsplat as its backbone.</data>
  <data key="d3">chunk-50e33da257497d62c9963654a61913d2</data>
