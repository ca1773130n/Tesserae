  <data key="d12">1778876028</data>
  <data key="d13"></data>
</edge>
<edge source="Viewpoint-Conditional Diffusion Model" target="Relative Camera Transformation">
  <data key="d7">1.0</data>
  <data key="d8">The viewpoint-conditional diffusion model conditions generation on a relative camera transformation expressed as elevation, azimuth, and radius.</data>
  <data key="d9">conditioning,viewpoint control</data>
  <data key="d10">chunk-7d4bb138a75a3adf4eebfac8bdf1be29</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2303-11328/paper.md</data>
  <data key="d12">1778876028</data>
  <data key="d13"></data>
</edge>
<edge source="Viewpoint-Conditional Diffusion Model" target="Objaverse Synthetic 3D Dataset">
  <data key="d7">1.0</data>
  <data key="d8">The viewpoint-conditional diffusion model is trained using rendered views from the Objaverse synthetic 3D dataset.</data>
  <data key="d9">synthetic rendering,training data</data>
  <data key="d10">chunk-7d4bb138a75a3adf4eebfac8bdf1be29</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2303-11328/paper.md</data>
  <data key="d12">1778876028</data>
  <data key="d13"></data>
</edge>
<edge source="Viewpoint-Conditional Diffusion Model" target="Latent Diffusion Objective">
  <data key="d7">1.0</data>
  <data key="d8">The viewpoint-conditional diffusion model is fit with a standard latent diffusion objective.</data>
  <data key="d9">optimization,training objective</data>
  <data key="d10">chunk-7d4bb138a75a3adf4eebfac8bdf1be29</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2303-11328/paper.md</data>
