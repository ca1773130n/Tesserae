  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875659</data>
  <data key="d6"></data>
</node>
<node id="Perp-Neg">
  <data key="d0">Perp-Neg</data>
  <data key="d1">method</data>
  <data key="d2">Perp-Neg is a supported method intended to alleviate the multi-head problem in text-to-3D and is supported for both Stable Diffusion and DeepFloyd-IF.</data>
  <data key="d3">chunk-cee14ff0001178656f392a3bf199e70c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
