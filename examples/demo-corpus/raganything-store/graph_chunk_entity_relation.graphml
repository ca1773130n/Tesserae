  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2312-06741/paper.md</data>
  <data key="d5">1778876350</data>
  <data key="d6"></data>
</node>
<node id="Monocular Gaussian SLAM">
  <data key="d0">Monocular Gaussian SLAM</data>
  <data key="d1">concept</data>
  <data key="d2">Monocular Gaussian SLAM is the practical direction for monocular SLAM established by MonoGS and represented by the released MonoGS code.</data>
  <data key="d3">chunk-5a20b3ebc3dcc9adfa50adfa770ad6d2</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2312-06741/paper.md</data>
