<node id="Block-NeRF">
  <data key="d0">Block-NeRF</data>
  <data key="d1">method</data>
  <data key="d2">Block-NeRF is a subsequent radiance-field method for city-scale scenes that adopted the appearance-embedding approach.</data>
  <data key="d3">chunk-501dafee6515bd66912047d0b36d43f9</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2008-02268/paper.md</data>
