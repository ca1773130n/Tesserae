  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Full Evaluation">
  <data key="d0">Full Evaluation</data>
  <data key="d1">method</data>
  <data key="d2">Full Evaluation is the evaluation process that can run on pre-trained models and can optionally skip training or rendering.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="full_eval.py">
  <data key="d0">full_eval.py</data>
  <data key="d1">artifact</data>
  <data key="d2">full_eval.py is the script used to run full evaluation, compute metrics, and control whether training, rendering, or metrics calculation are skipped.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
