  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="CUDA SDK 11.8">
  <data key="d0">CUDA SDK 11.8</data>
  <data key="d1">artifact</data>
  <data key="d2">CUDA SDK 11.8 is the specific CUDA SDK version used in the described setup.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Hardware Requirements">
  <data key="d0">Hardware Requirements</data>
  <data key="d1">content</data>
  <data key="d2">Hardware Requirements are the listed GPU, graphics, memory, and CUDA capability prerequisites for using the interactive viewers.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Software Requirements">
  <data key="d0">Software Requirements</data>
  <data key="d1">content</data>
  <data key="d2">Software Requirements are the listed compiler, development environment, and CUDA SDK prerequisites for building or using the interactive viewers.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Opacity Reset Frequency">
  <data key="d0">Opacity Reset Frequency</data>
  <data key="d1">concept</data>
  <data key="d2">Opacity Reset Frequency is a training setting that controls how frequently opacity is reset, with a default value of 3_000.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Lambda Dssim">
  <data key="d0">Lambda Dssim</data>
  <data key="d1">concept</data>
  <data key="d2">Lambda Dssim is a training parameter that controls the influence of SSIM on total loss from 0 to 1, with a default value of 0.2.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Percent Dense">
  <data key="d0">Percent Dense</data>
  <data key="d1">concept</data>
  <data key="d2">Percent Dense is a training parameter that defines the percentage of scene extent a point must exceed to be forcibly densified, with a default value of 0.01.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="MipNeRF360 Scenes">
  <data key="d0">MipNeRF360 Scenes</data>
  <data key="d1">data</data>
  <data key="d2">MipNeRF360 Scenes are hosted data scenes provided by the paper authors.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Tanks&amp;Temples">
  <data key="d0">Tanks&amp;Temples</data>
  <data key="d1">data</data>
  <data key="d2">Tanks&amp;Temples is a data set for which SfM data sets are provided.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="SfM Data Sets">
  <data key="d0">SfM Data Sets</data>
  <data key="d1">data</data>
  <data key="d2">SfM Data Sets are provided input data sets for Tanks&amp;Temples and Deep Blending.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Output Directory">
  <data key="d0">Output Directory</data>
  <data key="d1">location</data>
  <data key="d2">Output Directory is the directory where trained models are written when no output model directory is provided.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Train-Test Split">
  <data key="d0">Train-Test Split</data>
  <data key="d1">method</data>
  <data key="d2">Train-Test Split is a dataset partitioning method enabled by the eval flag for evaluation.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Train.py">
  <data key="d0">Train.py</data>
  <data key="d1">artifact</data>
  <data key="d2">Train.py is a script used to train models from a COLMAP or NeRF Synthetic data set, optionally with a train-test split.&lt;SEP&gt;`Train.py` is a training script that is run with dataset paths, ports, experiment names, configuration files, and optional checkpoint arguments.&lt;SEP&gt;Train.py is a training script used to start model training with specified dataset path, GPU count, and learning rate arguments.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c&lt;SEP&gt;chunk-5d8dc07a758da2f544255725b8c6e1a2&lt;SEP&gt;chunk-5160cf1bfca5ef8dc4dd9f099386ea9e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/readme.md</data>
  <data key="d5">1778876659</data>
  <data key="d6"></data>
</node>
<node id="Render.py">
  <data key="d0">Render.py</data>
  <data key="d1">artifact</data>
  <data key="d2">Render.py is a script used to generate renderings from trained or pre-trained models and can take a source data path when needed.&lt;SEP&gt;`Render.py` is a rendering script that is used to render images from a trained model path with a configuration file.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c&lt;SEP&gt;chunk-5d8dc07a758da2f544255725b8c6e1a2</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Metrics.py">
  <data key="d0">Metrics.py</data>
  <data key="d1">artifact</data>
  <data key="d2">Metrics.py is a script used to compute error metrics on renderings or model paths.&lt;SEP&gt;`Metrics.py` is an evaluation script that is used to evaluate a model from a specified model path.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c&lt;SEP&gt;chunk-5d8dc07a758da2f544255725b8c6e1a2</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md</data>
  <data key="d5">1778875929</data>
  <data key="d6"></data>
</node>
<node id="Full_Eval.py">
  <data key="d0">Full_Eval.py</data>
  <data key="d1">artifact</data>
  <data key="d2">Full_Eval.py is a script that specifies the evaluation routine and demonstrates additional parameters such as alternative image directories.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="COLMAP Data Set">
  <data key="d0">COLMAP Data Set</data>
  <data key="d1">data</data>
  <data key="d2">COLMAP Data Set is a source data set type accepted by the training and rendering scripts.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="NeRF Synthetic Data Set">
  <data key="d0">NeRF Synthetic Data Set</data>
  <data key="d1">data</data>
  <data key="d2">NeRF Synthetic Data Set is a source data set type accepted by the training script and used in white-background evaluation.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="MipNeRF360-Style Training-Test Split">
  <data key="d0">MipNeRF360-Style Training-Test Split</data>
  <data key="d1">method</data>
  <data key="d2">MipNeRF360-Style Training-Test Split is an evaluation split style enabled by the eval flag in rendering and evaluation workflows.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Release Codebase">
  <data key="d0">Release Codebase</data>
  <data key="d1">artifact</data>
  <data key="d2">Release Codebase is the earlier codebase used to create the pre-trained models.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="Current Codebase">
  <data key="d0">Current Codebase</data>
  <data key="d1">artifact</data>
  <data key="d2">Current Codebase is the cleaned-up codebase that includes bugfixes and can produce evaluation metrics different from those reported in the paper.</data>
  <data key="d3">chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="LatentSplat Paper">
  <data key="d0">LatentSplat Paper</data>
  <data key="d1">content</data>
  <data key="d2">LatentSplat Paper is a research paper titled "latentSplat: Autoencoding Variational Gaussians for Fast Generalizable 3D Reconstruction" published on March 24, 2024.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
