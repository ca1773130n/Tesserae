  <data key="d0">Evaluation Images</data>
  <data key="d1">data</data>
  <data key="d2">Evaluation Images are the paper's image sets that can be used to compute metrics while skipping rendering and without providing source datasets.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="The Paper">
  <data key="d0">The Paper</data>
  <data key="d1">content</data>
  <data key="d2">The Paper is the source associated with the evaluation images referenced for metric computation.&lt;SEP&gt;The paper is the referenced work in which `colmap.sh` is always used to generate dense point clouds and then downsample them.</data>
  <data key="d3">chunk-eadedf8ea91fdbae049617371c868a2e&lt;SEP&gt;chunk-5d8dc07a758da2f544255725b8c6e1a2</data>
