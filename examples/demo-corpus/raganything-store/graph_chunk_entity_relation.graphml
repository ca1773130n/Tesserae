  <data key="d0">Christopher Wewer</data>
  <data key="d1">person</data>
  <data key="d2">Christopher Wewer is an author of the latentSplat paper.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Kevin Raj">
  <data key="d0">Kevin Raj</data>
  <data key="d1">person</data>
  <data key="d2">Kevin Raj is an author of the latentSplat paper.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Eddy Ilg">
  <data key="d0">Eddy Ilg</data>
  <data key="d1">person</data>
  <data key="d2">Eddy Ilg is an author of the latentSplat paper.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Bernt Schiele">
  <data key="d0">Bernt Schiele</data>
  <data key="d1">person</data>
  <data key="d2">Bernt Schiele is an author of the latentSplat paper.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Jan Eric Lenssen">
  <data key="d0">Jan Eric Lenssen</data>
  <data key="d1">person</data>
  <data key="d2">Jan Eric Lenssen is an author of the latentSplat paper.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Generalizable 3D Reconstruction">
  <data key="d0">Generalizable 3D Reconstruction</data>
  <data key="d1">concept</data>
  <data key="d2">Generalizable 3D Reconstruction is the task of reconstructing 3D scenes in a way that transfers across scenes and datasets.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Regression-Based Feed-Forward Models">
  <data key="d0">Regression-Based Feed-Forward Models</data>
  <data key="d1">method</data>
  <data key="d2">Regression-Based Feed-Forward Models are reconstruction methods that infer outputs directly and are described as fast and clean in reconstruction but weak at interpolation under large view changes.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Generative Methods">
  <data key="d0">Generative Methods</data>
  <data key="d1">method</data>
  <data key="d2">Generative Methods are reconstruction approaches that produce richer extrapolations but are usually slow or limited to small scenes.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="PixelSplat">
  <data key="d0">PixelSplat</data>
  <data key="d1">content</data>
  <data key="d2">PixelSplat is an example of a regression-based feed-forward reconstruction model mentioned for clean reconstruction performance.&lt;SEP&gt;PixelSplat is a feed-forward Gaussian predictor named as part of the broader family that includes AGG.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e&lt;SEP&gt;chunk-d81fdba1f24c6b674084889fda5183d4</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2401-04099/paper.md</data>
  <data key="d5">1778875872</data>
  <data key="d6"></data>
</node>
<node id="Variational 3D Gaussians">
  <data key="d0">Variational 3D Gaussians</data>
  <data key="d1">concept</data>
  <data key="d2">Variational 3D Gaussians are the latent probabilistic representation predicted by latentSplat for 3D reconstruction.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="3D Feature Gaussians">
  <data key="d0">3D Feature Gaussians</data>
  <data key="d1">concept</data>
  <data key="d2">3D Feature Gaussians are the core representation in latentSplat whose attributes encode means and variances in a learned latent space rather than raw colour.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Learned Latent Space">
  <data key="d0">Learned Latent Space</data>
  <data key="d1">concept</data>
  <data key="d2">Learned Latent Space is the feature space in which latentSplat encodes Gaussian means and variances.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Differentiable Rasteriser">
  <data key="d0">Differentiable Rasteriser</data>
  <data key="d1">method</data>
  <data key="d2">Differentiable Rasteriser is the standard rasterization method used to splat sampled Gaussian instances to the image plane.&lt;SEP&gt;The differentiable rasteriser is the rendering component retained by GS-SLAM and MonoGS from the base 3DGS paper.&lt;SEP&gt;Differentiable Rasteriser is the standard splatting component used to render the effective 3D Gaussians produced from the 4D field.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e&lt;SEP&gt;chunk-c5c7f1e459e9c1753c0a4eb10eae7e1d&lt;SEP&gt;chunk-393d4b1d50fb3d20d718f84708cec66c</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/daily/2026-04-30/digest.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2402-03307/paper.md</data>
  <data key="d5">1778876986</data>
  <data key="d6"></data>
</node>
<node id="2D Generative Decoder">
  <data key="d0">2D Generative Decoder</data>
  <data key="d1">method</data>
  <data key="d2">2D Generative Decoder is a lightweight decoder that converts splatted latent samples into pixels and provides generative inductive bias during training.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Generative Prior">
  <data key="d0">Generative Prior</data>
  <data key="d1">concept</data>
  <data key="d2">Generative Prior is the learned prior from real video data that guides samples in uncertain regions.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Real Video Data">
  <data key="d0">Real Video Data</data>
  <data key="d1">data</data>
  <data key="d2">Real Video Data is the training data source used entirely for latentSplat without explicit 3D supervision.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Multi-View Consistency Loss">
  <data key="d0">Multi-View Consistency Loss</data>
  <data key="d1">method</data>
  <data key="d2">Multi-View Consistency Loss is the training loss that ties sampled reconstructions back to the input frames.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Explicit 3D Supervision">
  <data key="d0">Explicit 3D Supervision</data>
  <data key="d1">concept</data>
  <data key="d2">Explicit 3D Supervision is a form of direct 3D training signal that latentSplat does not rely on.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Cross-Dataset Behaviour">
  <data key="d0">Cross-Dataset Behaviour</data>
  <data key="d1">concept</data>
  <data key="d2">Cross-Dataset Behaviour is the ability of a reconstruction method to perform well across different datasets.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Diffusion-Style Sampling">
  <data key="d0">Diffusion-Style Sampling</data>
  <data key="d1">method</data>
  <data key="d2">Diffusion-Style Sampling is a later sampling-oriented approach that the paper is said to foreshadow for feed-forward 3D reconstruction.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="latentSplat: Autoencoding Variational Gaussians for Fast Generalizable 3D Reconstruction">
  <data key="d0">latentSplat: Autoencoding Variational Gaussians for Fast Generalizable 3D Reconstruction</data>
  <data key="d1">content</data>
  <data key="d2">latentSplat: Autoencoding Variational Gaussians for Fast Generalizable 3D Reconstruction is a research paper that introduces latentSplat and describes its variational Gaussian approach for fast generalizable 3D reconstruction.</data>
  <data key="d3">chunk-b4a36dbf1bfe982e8516ef5fb0a1dd0e</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d5">1778875535</data>
  <data key="d6"></data>
</node>
<node id="Erik Sandström">
  <data key="d0">Erik Sandström</data>
  <data key="d1">person</data>
  <data key="d2">Erik Sandström is an author of Point-SLAM.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875618</data>
  <data key="d6"></data>
</node>
<node id="Yue Li">
  <data key="d0">Yue Li</data>
  <data key="d1">person</data>
  <data key="d2">Yue Li is an author of Point-SLAM.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875618</data>
  <data key="d6"></data>
</node>
<node id="Luc Van Gool">
  <data key="d0">Luc Van Gool</data>
  <data key="d1">person</data>
  <data key="d2">Luc Van Gool is an author of Point-SLAM.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875618</data>
  <data key="d6"></data>
</node>
<node id="Martin R. Oswald">
  <data key="d0">Martin R. Oswald</data>
  <data key="d1">person</data>
  <data key="d2">Martin R. Oswald is an author of Point-SLAM.&lt;SEP&gt;Martin R. Oswald is an author of the NICE-SLAM paper.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17&lt;SEP&gt;chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Point Cloud">
  <data key="d0">Point Cloud</data>
  <data key="d1">data</data>
  <data key="d2">Point Cloud is the explicit anchor structure used by Point-SLAM to store features for the neural scene representation, with density adapted to local scene complexity.&lt;SEP&gt;Point Cloud is the sparse data produced by Structure From Motion and used to initialise Gaussians near the true surface.&lt;SEP&gt;Point Cloud is the intermediate 3D representation used in LucidDreamer, formed by lifting generated images into 3D and progressively aggregating new chunks of points before Gaussian Splatting optimisation.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17&lt;SEP&gt;chunk-d445282e0f2225e2a32ef51280563a09&lt;SEP&gt;chunk-2fd2757a4334bd3990412235a6cbd419</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2308-04079/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2311-13384/paper.md</data>
  <data key="d5">1778876028</data>
  <data key="d6"></data>
</node>
<node id="Neural Scene Representation">
  <data key="d0">Neural Scene Representation</data>
  <data key="d1">concept</data>
  <data key="d2">Neural Scene Representation is the scene model whose features are anchored in a point cloud in Point-SLAM.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875618</data>
  <data key="d6"></data>
</node>
<node id="RGBD Frames">
  <data key="d0">RGBD Frames</data>
  <data key="d1">data</data>
  <data key="d2">RGBD Frames are the incoming sensor observations from which Point-SLAM incrementally grows its point set and against which it compares synthesized colour and depth.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875620</data>
  <data key="d6"></data>
</node>
<node id="RGBD-Based Re-Rendering Loss">
  <data key="d0">RGBD-Based Re-Rendering Loss</data>
  <data key="d1">method</data>
  <data key="d2">RGBD-Based Re-Rendering Loss is the optimization objective in Point-SLAM that compares synthesized colour and depth against the incoming sensor stream and drives updates to the map representation and camera pose.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875620</data>
  <data key="d6"></data>
</node>
<node id="Anisotropic Gaussian Primitives">
  <data key="d0">Anisotropic Gaussian Primitives</data>
  <data key="d1">concept</data>
  <data key="d2">Anisotropic Gaussian Primitives are the explicit primitives used by Gaussian Splatting SLAM instead of point anchors.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875620</data>
  <data key="d6"></data>
</node>
<node id="Per-Point Feature Vectors">
  <data key="d0">Per-Point Feature Vectors</data>
  <data key="d1">data</data>
  <data key="d2">Per-Point Feature Vectors are the feature values attached to points in the point cloud and updated by gradient optimization in Point-SLAM.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875620</data>
  <data key="d6"></data>
</node>
<node id="Reliability Check">
  <data key="d0">Reliability Check</data>
  <data key="d1">method</data>
  <data key="d2">Reliability Check is a mechanism applied to new candidate points to prevent the point cloud from absorbing transient observations and to keep the active point set bounded.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875620</data>
  <data key="d6"></data>
</node>
<node id="Input-Adaptive Neural Map Representations">
  <data key="d0">Input-Adaptive Neural Map Representations</data>
  <data key="d1">concept</data>
  <data key="d2">Input-Adaptive Neural Map Representations are neural map designs whose structure adapts to local input information density, and Point-SLAM remains a common citation for this idea in real-time SLAM.</data>
  <data key="d3">chunk-0a914c77868426e1f8d5848af2165c17</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2304-04278/paper.md</data>
  <data key="d5">1778875620</data>
  <data key="d6"></data>
</node>
<node id="NICE-SLAM: Neural Implicit Scalable Encoding for SLAM">
  <data key="d0">NICE-SLAM: Neural Implicit Scalable Encoding for SLAM</data>
  <data key="d1">content</data>
  <data key="d2">NICE-SLAM: Neural Implicit Scalable Encoding for SLAM is a paper describing the NICE-SLAM system and its approach to scalable neural-implicit SLAM.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875624</data>
  <data key="d6"></data>
</node>
<node id="Zihan Zhu">
  <data key="d0">Zihan Zhu</data>
  <data key="d1">person</data>
  <data key="d2">Zihan Zhu is an author of the NICE-SLAM paper.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875624</data>
  <data key="d6"></data>
</node>
<node id="Viktor Larsson">
  <data key="d0">Viktor Larsson</data>
  <data key="d1">person</data>
  <data key="d2">Viktor Larsson is an author of the NICE-SLAM paper.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875624</data>
  <data key="d6"></data>
</node>
<node id="Weiwei Xu">
  <data key="d0">Weiwei Xu</data>
  <data key="d1">person</data>
  <data key="d2">Weiwei Xu is an author of the NICE-SLAM paper.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875624</data>
  <data key="d6"></data>
</node>
<node id="Hujun Bao">
  <data key="d0">Hujun Bao</data>
  <data key="d1">person</data>
  <data key="d2">Hujun Bao is an author of the NICE-SLAM paper.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875624</data>
  <data key="d6"></data>
</node>
<node id="Zhaopeng Cui">
  <data key="d0">Zhaopeng Cui</data>
  <data key="d1">person</data>
  <data key="d2">Zhaopeng Cui is an author of the NICE-SLAM paper.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875624</data>
  <data key="d6"></data>
</node>
<node id="IMap">
  <data key="d0">IMap</data>
  <data key="d1">method</data>
  <data key="d2">iMAP is described as the first neural-implicit SLAM system and as the baseline whose scene-wide shared MLP creates scaling, over-smoothing, and forgetting problems that NICE-SLAM addresses.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Hierarchical Feature Grid">
  <data key="d0">Hierarchical Feature Grid</data>
  <data key="d1">method</data>
  <data key="d2">Hierarchical Feature Grid is the scalable scene encoding used by NICE-SLAM, built from multiple voxel grids at different resolutions.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Monolithic MLP">
  <data key="d0">Monolithic MLP</data>
  <data key="d1">method</data>
  <data key="d2">Monolithic MLP is the single shared scene-wide network architecture used by iMAP that does not scale well to larger spaces.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Voxel Grids">
  <data key="d0">Voxel Grids</data>
  <data key="d1">artifact</data>
  <data key="d2">Voxel Grids are the coarse, mid, and fine resolution grids that store local geometric features in NICE-SLAM.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Decoder MLP">
  <data key="d0">Decoder MLP</data>
  <data key="d1">method</data>
  <data key="d2">Decoder MLP is the small shared network in NICE-SLAM that converts trilinearly interpolated features into occupancy and color, and uses pre-trained geometric priors.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="TSDF-Fusion Baselines">
  <data key="d0">TSDF-Fusion Baselines</data>
  <data key="d1">method</data>
  <data key="d2">TSDF-Fusion Baselines are classical SLAM baselines used for comparison with NICE-SLAM.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Vox-Fusion">
  <data key="d0">Vox-Fusion</data>
  <data key="d1">method</data>
  <data key="d2">Vox-Fusion is a neural-implicit SLAM follow-up named as part of the wave influenced by NICE-SLAM.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Teed">
  <data key="d0">Teed</data>
  <data key="d1">person</data>
  <data key="d2">Teed is cited as a co-author associated with DROID-SLAM.&lt;SEP&gt;Teed is a coauthor of the DROID-SLAM paper published in 2021.&lt;SEP&gt;Teed is a co-author credited with DeepV2D.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69&lt;SEP&gt;chunk-a57ecf4979daf463711507fe01462548&lt;SEP&gt;chunk-bb1234ddae6b39821bcc34ebe785c813</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/about.md&lt;SEP&gt;examples/demo-corpus/data/research/daily/2026-04-10/digest.md</data>
  <data key="d5">1778876755</data>
  <data key="d6"></data>
</node>
<node id="Deng">
  <data key="d0">Deng</data>
  <data key="d1">person</data>
  <data key="d2">Deng is cited as a co-author associated with DROID-SLAM.&lt;SEP&gt;Deng is a coauthor of the DROID-SLAM paper published in 2021.&lt;SEP&gt;Deng is a co-author credited with DeepV2D.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69&lt;SEP&gt;chunk-a57ecf4979daf463711507fe01462548&lt;SEP&gt;chunk-bb1234ddae6b39821bcc34ebe785c813</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/princeton-vl-droid-slam/about.md&lt;SEP&gt;examples/demo-corpus/data/research/daily/2026-04-10/digest.md</data>
  <data key="d5">1778876755</data>
  <data key="d6"></data>
</node>
<node id="Mapping Thread">
  <data key="d0">Mapping Thread</data>
  <data key="d1">method</data>
  <data key="d2">Mapping Thread is the NICE-SLAM process that fixes the camera pose and updates the scene grids over a sliding window of keyframes.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Tracking Thread">
  <data key="d0">Tracking Thread</data>
  <data key="d1">method</data>
  <data key="d2">Tracking Thread is the NICE-SLAM process that fixes the scene and refines the latest camera pose by minimizing RGB-D photometric and geometric losses.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Keyframes">
  <data key="d0">Keyframes</data>
  <data key="d1">data</data>
  <data key="d2">Keyframes are the frames in a sliding window used by the mapping process to update the scene grids in NICE-SLAM.&lt;SEP&gt;Keyframes are camera path data points that can be inserted from the current perspective and exported to a JSON file.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69&lt;SEP&gt;chunk-5b9702cfd82aaa0f9d50ba7409bbecf8</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876505</data>
  <data key="d6"></data>
</node>
<node id="RGB-D Photometric and Geometric Losses">
  <data key="d0">RGB-D Photometric and Geometric Losses</data>
  <data key="d1">method</data>
  <data key="d2">RGB-D Photometric and Geometric Losses are the optimization objectives used by NICE-SLAM for tracking and described as the same losses used across mapping and tracking.</data>
  <data key="d3">chunk-dea341f1a2c850107557c2c2de09ba69</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2112-12130/paper.md</data>
  <data key="d5">1778875625</data>
  <data key="d6"></data>
</node>
<node id="Zehao Yu">
  <data key="d0">Zehao Yu</data>
  <data key="d1">person</data>
  <data key="d2">Zehao Yu is an author of MonoSDF.&lt;SEP&gt;Zehao Yu is an author of 2D Gaussian Splatting for Geometrically Accurate Radiance Fields.</data>
  <data key="d3">chunk-39dac1db0f50be2348ba37c8912fe321&lt;SEP&gt;chunk-6ec02429fab7e72a6a23d2a0f735836e</data>
