</edge>
<edge source="Sinusoidal Positional Encoding" target="Coordinate MLPs">
  <data key="d7">1.0</data>
  <data key="d8">Sinusoidal Positional Encoding is said to make coordinate MLPs capable of fitting high frequencies.</data>
  <data key="d9">enables,high-frequency fitting</data>
