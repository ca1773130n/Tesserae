  <data key="d5">1778876504</data>
  <data key="d6"></data>
</node>
<node id="ODC-By 1.0 License">
  <data key="d0">ODC-By 1.0 License</data>
  <data key="d1">content</data>
  <data key="d2">The ODC-By 1.0 license is the license under which the renderings as a whole are released.</data>
  <data key="d3">chunk-d1cb4f77562fea889c9e32a8c9b6b118</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/readme.md</data>
