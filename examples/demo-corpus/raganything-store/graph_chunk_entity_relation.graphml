</node>
<node id="Multi-Resolution Grid Encoder">
  <data key="d0">Multi-Resolution Grid Encoder</data>
  <data key="d1">method</data>
  <data key="d2">Multi-Resolution Grid Encoder is the method used to implement the NeRF backbone and enable faster rendering.</data>
  <data key="d3">chunk-cee14ff0001178656f392a3bf199e70c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875660</data>
  <data key="d6"></data>
</node>
