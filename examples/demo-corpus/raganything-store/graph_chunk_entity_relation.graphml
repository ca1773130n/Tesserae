  <data key="d1">content</data>
  <data key="d2">EndoGaussian: Real-time Gaussian Splatting for Dynamic Endoscopic Scene Reconstruction is listed as an awesome concurrent or related work.</data>
  <data key="d3">chunk-5d8dc07a758da2f544255725b8c6e1a2</data>
