  <data key="d12">1778876217</data>
  <data key="d13"></data>
</edge>
<edge source="NeRF" target="Mip-NeRF">
  <data key="d7">2.0</data>
  <data key="d8">Mip-NeRF is presented as a modified neural radiance field method that addresses a fundamental sampling problem in NeRF.&lt;SEP&gt;Mip-NeRF is described as an aliasing-aware revision of NeRF in which rays become cones and point samples become integrated positional encodings over conical frustums.</data>
  <data key="d9">aliasing awareness,extension,method revision,replacement</data>
  <data key="d10">chunk-24800bbb3bf5dc8182a3f3b86a0d5dad&lt;SEP&gt;chunk-ec770f62777c513047108cb79ba7aa75</data>
