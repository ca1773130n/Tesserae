</node>
<node id="Bo Dai">
  <data key="d0">Bo Dai</data>
  <data key="d1">person</data>
  <data key="d2">Bo Dai is an author of the paper Scaffold-GS: Structured 3D Gaussians for View-Adaptive Rendering.</data>
  <data key="d3">chunk-4b8d422b0944627b01e7c77ba8f039d8</data>
