  <data key="d5">1778876467</data>
  <data key="d6"></data>
</node>
<node id="NVlabs">
  <data key="d0">NVlabs</data>
  <data key="d1">organization</data>
  <data key="d2">NVlabs is the organization associated with the reference implementation repository instant-ngp.&lt;SEP&gt;NVlabs is the organization associated with the Instant-NGP repository and the Tiny-CUDA-NN framework links presented in the text.&lt;SEP&gt;NVlabs is the organization named in the linked GitHub paths associated with the referenced resources.</data>
  <data key="d3">chunk-71173d9786b13b28dc182e4c921d912b&lt;SEP&gt;chunk-eea3b682e8bd992578c8df7af80e379d&lt;SEP&gt;chunk-5d77e66aa7cc152f532934b3e4405857</data>
