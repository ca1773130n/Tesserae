<node id="Reference Images">
  <data key="d0">Reference Images</data>
  <data key="d1">data</data>
  <data key="d2">Reference images are resources provided by the repository and are used to create the error metrics reported in the paper.</data>
  <data key="d3">chunk-41e2a18164d88d58975577aab63d7325</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875511</data>
  <data key="d6"></data>
</node>
<node id="Error Metrics">
  <data key="d0">Error Metrics</data>
  <data key="d1">data</data>
  <data key="d2">Error metrics are the reported evaluation measures in the paper and are created using the provided reference images.</data>
  <data key="d3">chunk-41e2a18164d88d58975577aab63d7325</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875511</data>
  <data key="d6"></data>
</node>
