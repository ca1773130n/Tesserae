</edge>
<edge source="Coordinate-Based MLP" target="Sinusoidal Positional Encoding">
  <data key="d7">1.0</data>
  <data key="d8">Sinusoidal Positional Encoding transforms the coordinates into a higher-frequency space before they are processed by the Coordinate-Based MLP.</data>
