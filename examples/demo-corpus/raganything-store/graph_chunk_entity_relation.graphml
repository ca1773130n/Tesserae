<node id="Torsten Sattler">
  <data key="d0">Torsten Sattler</data>
  <data key="d1">person</data>
  <data key="d2">Torsten Sattler is an author of MonoSDF.</data>
  <data key="d3">chunk-39dac1db0f50be2348ba37c8912fe321</data>
