  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2403-16292/paper.md</data>
  <data key="d12">1778875535</data>
  <data key="d13"></data>
</edge>
<edge source="Multi-Object Scenes" target="SDS-Based Pipelines">
  <data key="d7">1.0</data>
  <data key="d8">SDS-Based Pipelines are described as collapsing when asked to generate Multi-Object Scenes with several distinct entities.</data>
  <data key="d9">failure mode,scene complexity</data>
  <data key="d10">chunk-8e84795d808a30ea730dabef6dcde2d3</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2402-07207/paper.md</data>
  <data key="d12">1778874826</data>
  <data key="d13"></data>
</edge>
<edge source="Large Language Model" target="LLM-Generated Layout">
  <data key="d7">1.0</data>
  <data key="d8">The Large Language Model produces the LLM-Generated Layout by translating a free-form scene description into an explicit object layout.</data>
  <data key="d9">layout generation,scene parsing</data>
  <data key="d10">chunk-8e84795d808a30ea730dabef6dcde2d3</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2402-07207/paper.md</data>
  <data key="d12">1778874826</data>
  <data key="d13"></data>
</edge>
<edge source="LLM-Generated Layout" target="Bounding Boxes">
  <data key="d7">1.0</data>
  <data key="d8">The LLM-Generated Layout contains approximate Bounding Boxes for named objects.</data>
  <data key="d9">object priors,spatial specification</data>
  <data key="d10">chunk-8e84795d808a30ea730dabef6dcde2d3</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2402-07207/paper.md</data>
  <data key="d12">1778874826</data>
  <data key="d13"></data>
</edge>
<edge source="LLM-Generated Layout" target="GaussianSplatting Representation">
  <data key="d7">1.0</data>
  <data key="d8">The LLM-Generated Layout serves as the prior for the layout-guided GaussianSplatting Representation.</data>
  <data key="d9">prior guidance,representation</data>
  <data key="d10">chunk-8e84795d808a30ea730dabef6dcde2d3</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2402-07207/paper.md</data>
  <data key="d12">1778874826</data>
  <data key="d13"></data>
</edge>
<edge source="LLM-Generated Layout" target="Instance-Scene Compositional Optimisation Mechanism">
  <data key="d7">1.0</data>
  <data key="d8">The Instance-Scene Compositional Optimisation Mechanism adjusts the initial coarse LLM-Generated Layout to make scale, contact, and relative positions more physically and semantically plausible.</data>
  <data key="d9">layout adjustment,plausibility refinement</data>
  <data key="d10">chunk-8e84795d808a30ea730dabef6dcde2d3</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2402-07207/paper.md</data>
  <data key="d12">1778874826</data>
  <data key="d13"></data>
</edge>
<edge source="Bounding Boxes" target="GaussianSplatting Representation">
  <data key="d7">1.0</data>
  <data key="d8">Bounding Boxes provide the per-object geometric priors that constrain optimisation in the GaussianSplatting Representation.</data>
  <data key="d9">geometric priors,optimisation constraints</data>
  <data key="d10">chunk-8e84795d808a30ea730dabef6dcde2d3</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2402-07207/paper.md</data>
  <data key="d12">1778874826</data>
  <data key="d13"></data>
</edge>
<edge source="Instance-Scene Compositional Optimisation Mechanism" target="Conditioned Diffusion Prior">
  <data key="d7">1.0</data>
  <data key="d8">The Instance-Scene Compositional Optimisation Mechanism is driven by a Conditioned Diffusion Prior during joint scene refinement.</data>
  <data key="d9">diffusion guidance,refinement driver</data>
  <data key="d10">chunk-8e84795d808a30ea730dabef6dcde2d3</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2402-07207/paper.md</data>
