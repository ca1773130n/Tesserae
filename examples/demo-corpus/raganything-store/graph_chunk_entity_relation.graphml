  <data key="d6"></data>
</node>
<node id="L1">
  <data key="d0">L1</data>
  <data key="d1">concept</data>
  <data key="d2">L1 is a metric computed by the training script over the test set at specified test iterations.</data>
  <data key="d3">chunk-f03bfcd22d34d1827ec44d4dfcce42df</data>
  <data key="d4">examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
