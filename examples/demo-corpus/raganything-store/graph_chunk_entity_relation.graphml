  <data key="d1">organization</data>
  <data key="d2">Hugging Face is the platform hosting the live demo and model weights, and is thanked for funding the demo.&lt;SEP&gt;Hugging Face is the platform from which DeepFloyd-IF usage conditions must be accepted and where custom checkpoints and optimization documentation are referenced.</data>
  <data key="d3">chunk-0d057f3bc5fa56c4a6477fe9f9195f8b&lt;SEP&gt;chunk-b0ea2d1fff273acbdf62338200407400</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/ashawkey-stable-dreamfusion/readme.md</data>
  <data key="d5">1778875661</data>
  <data key="d6"></data>
</node>
