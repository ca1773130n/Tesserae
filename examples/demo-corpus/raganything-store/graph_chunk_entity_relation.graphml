<edge source="DreamFusion" target="Text-to-3D Line">
  <data key="d7">1.0</data>
  <data key="d8">DreamFusion is cited as part of the text-to-3D line connected by Zero-1-to-3.</data>
  <data key="d9">representation,research area</data>
