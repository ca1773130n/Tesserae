  <data key="d0">requirements.txt</data>
  <data key="d1">content</data>
  <data key="d2">requirements.txt is the dependency file installed during the Zero-1-to-3 setup process with pip.</data>
  <data key="d3">chunk-0d057f3bc5fa56c4a6477fe9f9195f8b</data>
  <data key="d4">examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/readme.md</data>
