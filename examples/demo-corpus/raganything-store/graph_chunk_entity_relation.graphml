  <data key="d5">1778874861</data>
  <data key="d6"></data>
</node>
<node id="Songyou Peng">
  <data key="d0">Songyou Peng</data>
  <data key="d1">person</data>
  <data key="d2">Songyou Peng is an author of the UNISURF paper.&lt;SEP&gt;Songyou Peng is an author of the NICE-SLAM paper.&lt;SEP&gt;Songyou Peng is an author of MonoSDF.</data>
  <data key="d3">chunk-65491bb40aaff28e47124705eb1fff58&lt;SEP&gt;chunk-dea341f1a2c850107557c2c2de09ba69&lt;SEP&gt;chunk-39dac1db0f50be2348ba37c8912fe321</data>
