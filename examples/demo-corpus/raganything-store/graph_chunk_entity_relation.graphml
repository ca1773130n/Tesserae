  <data key="d1">concept</data>
  <data key="d2">Learned Priors are the priors paired with splatting in the next phase of the discussed research direction.</data>
  <data key="d3">chunk-a4716f0532d6b5d940a3893a269cfdc9</data>
  <data key="d4">examples/demo-corpus/data/research/weekly/2026-W17/synthesis.md</data>
  <data key="d5">1778875012</data>
