  <data key="d0">Camera-To-World Transformation Matrices</data>
  <data key="d1">data</data>
  <data key="d2">Camera-To-World Transformation Matrices are the transformations represented by stored 3x4 NumPy pose arrays.</data>
  <data key="d3">chunk-45d73dd21f95946d74e1b943beb1d384</data>
  <data key="d4">examples/demo-corpus/data/research/repos/bmild-nerf/readme.md</data>
  <data key="d5">1778876879</data>
  <data key="d6"></data>
