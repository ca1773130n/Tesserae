  <data key="d0">Qinhong Chen</data>
  <data key="d1">person</data>
  <data key="d2">Qinhong Chen is an author of Plenoxels: Radiance Fields without Neural Networks.&lt;SEP&gt;Qinhong Chen is an author of Plenoxels: Radiance Fields without Neural Networks.</data>
