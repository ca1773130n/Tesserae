<node id="PeRFception">
  <data key="d0">PeRFception</data>
  <data key="d1">artifact</data>
  <data key="d2">PeRFception is a project that uses Plenoxels with tuned parameters to generate a large dataset of radiance fields.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Artistic Radiance Fields">
  <data key="d0">Artistic Radiance Fields</data>
  <data key="d1">artifact</data>
  <data key="d2">Artistic Radiance Fields is a project associated with Kai Zhang and linked as an example use case related to Plenoxels.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Kai Zhang">
  <data key="d0">Kai Zhang</data>
  <data key="d1">person</data>
  <data key="d2">Kai Zhang is identified as associated with the Artistic Radiance Fields project.&lt;SEP&gt;Kai Zhang is an author of LRM: Large Reconstruction Model for Single Image to 3D.&lt;SEP&gt;Kai Zhang is an author of the Instant3D paper.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-faebadc81c39822f071629969e8b6a2b&lt;SEP&gt;chunk-22bc14784620637c470939b2097cd200</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2311-04400/paper.md&lt;SEP&gt;examples/demo-corpus/data/research/papers/arxiv-2311-06214/paper.md</data>
  <data key="d5">1778875860</data>
  <data key="d6"></data>
</node>
<node id="CUDA Toolkit">
  <data key="d0">CUDA Toolkit</data>
  <data key="d1">artifact</data>
  <data key="d2">CUDA Toolkit is a dependency whose version affects whether CUB must be installed separately for the library build.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="CUB">
  <data key="d0">CUB</data>
  <data key="d1">artifact</data>
  <data key="d2">CUB is a library that must be installed when the CUDA Toolkit version is older than 11 and may cause build errors if installed with CUDA 11 or later.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="NeRF-Synthetic">
  <data key="d0">NeRF-Synthetic</data>
  <data key="d1">data</data>
  <data key="d2">NeRF-Synthetic is a dataset format and dataset source supported by the repository backends.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="NSVF">
  <data key="d0">NSVF</data>
  <data key="d1">data</data>
  <data key="d2">NSVF is a dataset format supported by the repository backends and used for the processed Tanks and Temples dataset and for real data.&lt;SEP&gt;NSVF is a project whose data format is used as a reference for the custom dataset format.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="CO3D">
  <data key="d0">CO3D</data>
  <data key="d1">data</data>
  <data key="d2">CO3D is a dataset format supported by the repository backends.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Tanks and Temples">
  <data key="d0">Tanks and Temples</data>
  <data key="d1">data</data>
  <data key="d2">Tanks and Temples is a processed dataset provided in NSVF format with background.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="NeRF++">
  <data key="d0">NeRF++</data>
  <data key="d1">content</data>
  <data key="d2">NeRF++ is referenced as the source whose data should be identical to the provided Tanks and Temples data.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="ingp2nsvf.py">
  <data key="d0">ingp2nsvf.py</data>
  <data key="d1">artifact</data>
  <data key="d2">ingp2nsvf.py is a script provided to convert Instant-NGP data into NSVF format.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="opt/opt.py">
  <data key="d0">opt/opt.py</data>
  <data key="d1">artifact</data>
  <data key="d2">opt/opt.py is the file referenced for training a single scene.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="launch.sh">
  <data key="d0">launch.sh</data>
  <data key="d1">artifact</data>
  <data key="d2">launch.sh is the launch script used inside the opt directory to simplify training runs.&lt;SEP&gt;launch.sh is a script used to start training with an experiment name, GPU id, data directory, and config file.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="configs/syn.json">
  <data key="d0">configs/syn.json</data>
  <data key="d1">artifact</data>
  <data key="d2">configs/syn.json is a configuration file intended for NeRF-Synthetic scenes.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="configs/llff.json">
  <data key="d0">configs/llff.json</data>
  <data key="d1">artifact</data>
  <data key="d2">configs/llff.json is a configuration file intended for forward-facing scenes.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="configs/tnt.json">
  <data key="d0">configs/tnt.json</data>
  <data key="d1">artifact</data>
  <data key="d2">configs/tnt.json is a configuration file intended for Tanks and Temples scenes.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="opt/render_imgs.py">
  <data key="d0">opt/render_imgs.py</data>
  <data key="d1">artifact</data>
  <data key="d2">opt/render_imgs.py is the script referenced for evaluation by rendering images from a checkpoint.&lt;SEP&gt;opt/render_imgs.py is a script used to render images from a checkpoint and dataset during evaluation.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="NeRF-Blender">
  <data key="d0">NeRF-Blender</data>
  <data key="d1">data</data>
  <data key="d2">NeRF-Blender is a dataset format supported by the repository backends and subject to automatic dataset detection.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="environment.yml">
  <data key="d0">environment.yml</data>
  <data key="d1">artifact</data>
  <data key="d2">environment.yml is the environment specification file used to create the recommended conda virtual environment for the project.&lt;SEP&gt;environment.yml is the conda environment setup file used to create the nerf environment with the required dependencies.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-ee99e1fe0369d50218c77432ff216939</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/bmild-nerf/readme.md</data>
  <data key="d5">1778876879</data>
  <data key="d6"></data>
</node>
<node id="Windows">
  <data key="d0">Windows</data>
  <data key="d1">location</data>
  <data key="d2">Windows is an operating system that is stated to be not officially supported by the project.&lt;SEP&gt;Windows is the operating system on which some users experience problems building the submodules.&lt;SEP&gt;Windows is the operating system context in which Visual Studio 2019 was used.&lt;SEP&gt;Windows is an operating system platform referenced for gsplat installation guidance, tutorial material, and source builds.&lt;SEP&gt;Windows is the operating system for which prebuilt Instant-NGP releases are offered in the text.&lt;SEP&gt;Windows is an operating system platform supported for building Instant-NGP.&lt;SEP&gt;Windows is the operating system environment referenced in troubleshooting guidance for CUDA and Visual Studio integration issues.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-f03bfcd22d34d1827ec44d4dfcce42df&lt;SEP&gt;chunk-eadedf8ea91fdbae049617371c868a2e&lt;SEP&gt;chunk-f175249759ca8a973f8918ff16dfac34&lt;SEP&gt;chunk-67aca36ec8eb49d9f01fa3055f69d8fd&lt;SEP&gt;chunk-eea3b682e8bd992578c8df7af80e379d&lt;SEP&gt;chunk-5b9702cfd82aaa0f9d50ba7409bbecf8</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/nerfstudio-project-gsplat/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876504</data>
  <data key="d6"></data>
</node>
<node id="Linux">
  <data key="d0">Linux</data>
  <data key="d1">location</data>
  <data key="d2">Linux is an operating system on which the project has been tested.&lt;SEP&gt;Linux is an operating system platform supported by certain pre-compiled gsplat wheels.&lt;SEP&gt;Linux is the operating system for which users are instructed to build Instant-NGP themselves.&lt;SEP&gt;Linux is an operating system platform supported for building Instant-NGP.&lt;SEP&gt;Linux is the operating system environment referenced in troubleshooting guidance for CUDA environment variable configuration.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-f175249759ca8a973f8918ff16dfac34&lt;SEP&gt;chunk-67aca36ec8eb49d9f01fa3055f69d8fd&lt;SEP&gt;chunk-eea3b682e8bd992578c8df7af80e379d&lt;SEP&gt;chunk-5b9702cfd82aaa0f9d50ba7409bbecf8</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/nerfstudio-project-gsplat/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876504</data>
  <data key="d6"></data>
</node>
<node id="Real Lego Capture">
  <data key="d0">Real Lego Capture</data>
  <data key="d1">data</data>
  <data key="d2">Real Lego Capture is a downloadable real-data dataset referenced in the dataset instructions.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Pretrained Checkpoints">
  <data key="d0">Pretrained Checkpoints</data>
  <data key="d1">data</data>
  <data key="d2">Pretrained Checkpoints are pretrained model files made available through an external download link.&lt;SEP&gt;Pretrained Checkpoints are downloadable saved model states provided for the project.</data>
  <data key="d3">chunk-95e7570668ab2add22a107c42e84d859&lt;SEP&gt;chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Data Dir">
  <data key="d0">Data Dir</data>
  <data key="d1">data</data>
  <data key="d2">Data Dir is the dataset directory whose format is auto-detected by the system and is used as input for rendering and training commands.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Checkpoint">
  <data key="d0">Checkpoint</data>
  <data key="d1">artifact</data>
  <data key="d2">Checkpoint is a saved model file in `.npz` form that is used for rendering and conversion tasks.&lt;SEP&gt;Checkpoint is a saved training state that can be stored at specified iterations and used to continue training later.&lt;SEP&gt;A checkpoint is a saved training state that can be created during training and later loaded to resume training.&lt;SEP&gt;Checkpoint is the Objaverse-trained model artifact provided by the repository.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941&lt;SEP&gt;chunk-f03bfcd22d34d1827ec44d4dfcce42df&lt;SEP&gt;chunk-5d8dc07a758da2f544255725b8c6e1a2&lt;SEP&gt;chunk-c47e36db5dfb4966f1d4d610b06ac6bc</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/hustvl-4dgaussians/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/cvlab-columbia-zero123/about.md</data>
  <data key="d5">1778876990</data>
  <data key="d6"></data>
</node>
<node id="Ckpt/Exp_Name">
  <data key="d0">Ckpt/Exp_Name</data>
  <data key="d1">location</data>
  <data key="d2">Ckpt/Exp_Name is the directory path where checkpoints are stored for an experiment.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Evaluation">
  <data key="d0">Evaluation</data>
  <data key="d1">method</data>
  <data key="d2">Evaluation is the process of rendering outputs from a checkpoint and dataset for assessment.&lt;SEP&gt;Evaluation is the process of withholding a test set, rendering training and test sets, and producing error metrics.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941&lt;SEP&gt;chunk-4ace087a61df1fdd6d045f0f39a3166c</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md&lt;SEP&gt;examples/demo-corpus/data/research/repos/graphdeco-inria-gaussian-splatting/readme.md</data>
  <data key="d5">1778875512</data>
  <data key="d6"></data>
</node>
<node id="No_Imsave">
  <data key="d0">No_Imsave</data>
  <data key="d1">method</data>
  <data key="d2">No_Imsave is an option that disables saving all frames in order to avoid a very slow default rendering behavior.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Spiral Rendering">
  <data key="d0">Spiral Rendering</data>
  <data key="d1">method</data>
  <data key="d2">Spiral Rendering is a rendering procedure used to generate a spiral-view video from a checkpoint and dataset.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="opt/render_imgs_circle.py">
  <data key="d0">opt/render_imgs_circle.py</data>
  <data key="d1">artifact</data>
  <data key="d2">opt/render_imgs_circle.py is a script used to perform spiral rendering.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="Parallel Task Executor">
  <data key="d0">Parallel Task Executor</data>
  <data key="d1">method</data>
  <data key="d2">Parallel Task Executor is a scheduling system for running many tasks across scenes or hyperparameter settings.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="opt/autotune.py">
  <data key="d0">opt/autotune.py</data>
  <data key="d1">artifact</data>
  <data key="d2">opt/autotune.py is a script used to schedule evaluation, ablation, and hypertuning tasks automatically.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="tasks/eval.json">
  <data key="d0">tasks/eval.json</data>
  <data key="d1">artifact</data>
  <data key="d2">tasks/eval.json is a task configuration file used to train and evaluate all synthetic scenes after editing root paths.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="tasks/eval_ff.json">
  <data key="d0">tasks/eval_ff.json</data>
  <data key="d1">artifact</data>
  <data key="d2">tasks/eval_ff.json is a task configuration file used for forward-facing scenes.</data>
  <data key="d3">chunk-02c51c541bd8838daa93cb2a36760941</data>
  <data key="d4">examples/demo-corpus/data/research/repos/sxyu-svox2/readme.md</data>
  <data key="d5">1778874886</data>
  <data key="d6"></data>
</node>
<node id="tasks/eval_tnt.json">
  <data key="d0">tasks/eval_tnt.json</data>
  <data key="d1">artifact</data>
  <data key="d2">tasks/eval_tnt.json is a task configuration file used for Tanks and Temples scenes.</data>
