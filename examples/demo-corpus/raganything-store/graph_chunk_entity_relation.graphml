  <data key="d13"></data>
</edge>
<edge source="Integrated Positional Encoding" target="Multivariate Gaussian">
  <data key="d7">1.0</data>
  <data key="d8">Integrated Positional Encoding is defined as the expectation of NeRF's sinusoidal positional encoding under a multivariate Gaussian that approximates a conical frustum.</data>
  <data key="d9">approximation,expectation</data>
  <data key="d10">chunk-24800bbb3bf5dc8182a3f3b86a0d5dad</data>
  <data key="d11">examples/demo-corpus/data/research/papers/arxiv-2103-13415/paper.md</data>
  <data key="d12">1778875182</data>
  <data key="d13"></data>
</edge>
<edge source="Integrated Positional Encoding" target="Mipmapping">
  <data key="d7">1.0</data>
  <data key="d8">Integrated Positional Encoding produces analytically computable damped high-frequency features that match the anti-aliased multiscale behavior of classical mipmapping.</data>
  <data key="d9">anti-aliasing,multiscale behavior</data>
  <data key="d10">chunk-24800bbb3bf5dc8182a3f3b86a0d5dad</data>
