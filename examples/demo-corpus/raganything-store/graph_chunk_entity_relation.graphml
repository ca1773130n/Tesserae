  <data key="d0">Tiny-CUDA-NN PyTorch Extension</data>
  <data key="d1">artifact</data>
  <data key="d2">The Tiny-CUDA-NN PyTorch Extension is the recommended interface for editing and training the underlying hash encoding or neural network on a new task.</data>
  <data key="d3">chunk-67aca36ec8eb49d9f01fa3055f69d8fd</data>
  <data key="d4">examples/demo-corpus/data/research/repos/nvlabs-instant-ngp/readme.md</data>
  <data key="d5">1778876503</data>
  <data key="d6"></data>
</node>
