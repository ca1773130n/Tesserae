<node id="Coarse Network">
  <data key="d0">Coarse Network</data>
  <data key="d1">method</data>
  <data key="d2">Coarse Network is the component that estimates where mass lies along each ray in the hierarchical sampling scheme.</data>
  <data key="d3">chunk-ed61775b026776e3df7ec95d66d9c8df</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2003-08934/paper.md</data>
  <data key="d5">1778876009</data>
  <data key="d6"></data>
</node>
<node id="Fine Network">
  <data key="d0">Fine Network</data>
  <data key="d1">method</data>
  <data key="d2">Fine Network is the component that importance-samples around locations identified by the coarse network in the hierarchical sampling scheme.</data>
  <data key="d3">chunk-ed61775b026776e3df7ec95d66d9c8df</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2003-08934/paper.md</data>
  <data key="d5">1778876009</data>
  <data key="d6"></data>
</node>
<node id="Posed Multi-View Images">
  <data key="d0">Posed Multi-View Images</data>
  <data key="d1">data</data>
  <data key="d2">Posed Multi-View Images are the training data used to optimize the entire Neural Radiance Fields system.</data>
  <data key="d3">chunk-ed61775b026776e3df7ec95d66d9c8df</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2003-08934/paper.md</data>
  <data key="d5">1778876009</data>
  <data key="d6"></data>
</node>
<node id="SRN">
  <data key="d0">SRN</data>
  <data key="d1">method</data>
  <data key="d2">SRN is a contemporary method included among the approaches outperformed by Neural Radiance Fields.</data>
  <data key="d3">chunk-ed61775b026776e3df7ec95d66d9c8df</data>
  <data key="d4">examples/demo-corpus/data/research/papers/arxiv-2003-08934/paper.md</data>
  <data key="d5">1778876009</data>
  <data key="d6"></data>
</node>
<node id="NV">
  <data key="d0">NV</data>
  <data key="d1">method</data>
  <data key="d2">NV is a contemporary method included among the approaches outperformed by Neural Radiance Fields.</data>
