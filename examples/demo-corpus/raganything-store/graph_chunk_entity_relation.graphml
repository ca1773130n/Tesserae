  <data key="d12">1778876217</data>
  <data key="d13"></data>
</edge>
<edge source="NeRF" target="DreamGaussian">
  <data key="d7">2.0</data>
  <data key="d8">DreamGaussian replaces the NeRF backbone used in SDS-based methods.&lt;SEP&gt;DreamGaussian replaces the NeRF backbone in its architecture.</data>
  <data key="d9">backbone,backbone change,replacement</data>
  <data key="d10">chunk-c9fd8d6d633ccb294d8ac229c312a9a7&lt;SEP&gt;chunk-d585a450d31daf1370ab99c3ececfb44</data>
